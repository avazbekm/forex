# ============================================
# Forex Application - Environment Variables
# ============================================
# Copy this file to .env and update values
# This is a template - use example values below

# ============================================
# Docker Image Configuration
# ============================================
# Docker image name (change to your registry/username)
# Examples:
#   - muqimjon/forex   (rasmiy Docker Hub image)
#   - your-registry.com/forex
#   - forex            (faqat lokal build uchun)
DOCKER_IMAGE=muqimjon/forex

# Docker image tag (VERSIYA)
#   amd64 (oddiy serverlar):  3.0.0
#   arm64 (ARM serverlar):    arm64v3.0.0
# Eski versiyada qolmoqchi bo'lsangiz, shu yerda o'sha versiyani belgilang.
DOCKER_TAG=3.0.0


# ============================================
# PostgreSQL Database Configuration
# ============================================
# Username for PostgreSQL database
POSTGRES_USER=your-postgres-username

# Password for PostgreSQL database
# CHANGE THIS IN PRODUCTION!
POSTGRES_PASSWORD=your-secure-postgres-password

# Database name
POSTGRES_DB=forex


# ============================================
# PgAdmin Web Interface Configuration
# ============================================
# Email for PgAdmin login
PGADMIN_EMAIL=your-email@example.com

# Password for PgAdmin login
# CHANGE THIS IN PRODUCTION!
PGADMIN_PASSWORD=your-secure-pgadmin-password


# ============================================
# MinIO Object Storage Configuration
# ============================================
# MinIO root username
MINIO_ROOT_USER=your-minio-username

# MinIO root password (minimum 8 characters)
# CHANGE THIS IN PRODUCTION!
MINIO_ROOT_PASSWORD=your-secure-minio-password

# Bucket name for storing files
MINIO_BUCKET_NAME=forex-storage


# ============================================
# Backend API Configuration
# ============================================
# JWT Secret Key - Use long random string (64+ characters recommended)
# Generate with: openssl rand -base64 64
# CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=your-long-random-secret-key-change-this-in-production

# JWT Issuer (application name)
JWT_ISSUER=Forex

# JWT Audience (who can use the token)
JWT_AUDIENCE=AuditoryForex


# ============================================
# MinIO Public Endpoint Configuration
# ============================================
# This is the URL clients use to access MinIO
# For localhost testing: http://localhost:9000
# For production: http://your-server-ip:9000 or https://storage.yourdomain.com
MINIO_PUBLIC_ENDPOINT=http://your-server-domain-or-ip:9000


# ============================================
# File Upload Configuration
# ============================================
# Maximum file size in MB (backend validation)
# Frontend will compress images to ~500KB before upload
MAX_FILE_SIZE_MB=1


# ============================================
# HTTPS / Traefik (Cloudflare bitta subdomen + yo'llar)
# ============================================
# Faqat docker-compose.traefik.yml ishlatilganda kerak. Hammasi bitta domen ostida:
#   https://${DOMAIN}                      → API (WPF ilova SHUNI ishlatadi)
#   https://${DOMAIN}/pgadmin              → pgAdmin
#   https://${DOMAIN}/<MINIO_BUCKET_NAME>  → rasm fayllar (yuqoridagi bucket nomi)
# Cloudflare'da bitta A yozuv yetadi:  forex.sizning-domeningiz.uz -> SERVER_IP
DOMAIN=forex.sizning-domeningiz.uz

# Cloudflare API token (Let's Encrypt DNS-01 challenge uchun).
# Cloudflare → My Profile → API Tokens → "Edit zone DNS" shabloni → domeningiz.
CF_DNS_API_TOKEN=


# ============================================
# Backup (Zaxira agent) Configuration
# ============================================
# PostgreSQL bazasi + MinIO bucket'ini zaxiralab, rclone orqali tashqi joyga yuklaydi.
# Image: muqimjon/zaxira (BACKUP_DRIVER=postgres-minio docker-compose ichida belgilangan)

# ── Hub rejimi (ixtiyoriy) ──────────────────────────────────────────
# Bo'sh qoldirsangiz, agent standalone (.env) rejimda ishlaydi (yuqoridagi
# BACKUP_*/RCLONE_* sozlamalari bilan). To'ldirsangiz, agent Hub'ga ulanib,
# zaxiralarni brauzerdan boshqarish mumkin bo'ladi.
HUB_URL=
HUB_TOKEN=
AGENT_NAME=

# Loyiha nomi (zaxira fayllari shu nom bilan belgilanadi)
PROJECT_NAME=forex

# Vaqt mintaqasi (cron jadvali shunga qarab ishlaydi)
TZ=Asia/Tashkent

# Zaxira jadvali (cron format). Standart: har kuni 02:00
BACKUP_SCHEDULE=0 2 * * *

# Tashqi joyga yuklash jadvali (bo'sh bo'lsa, zaxira bilan birga yuklanadi)
UPLOAD_SCHEDULE=

# Eski zaxiralarni tozalash jadvali (bo'sh bo'lsa, yuklashdan keyin ishlaydi)
CLEANUP_SCHEDULE=

# Saqlash siyosati (retention)
MIN_LOCAL_BACKUPS=3
MAX_LOCAL_BACKUPS=7
MAX_REMOTE_BACKUPS=30

# Siqish darajasi (1-9; yuqori = kichikroq fayl, sekinroq)
COMPRESSION_LEVEL=6

# Zaxira shifrlash paroli (BO'SH QOLDIRMANG — maxfiy joyda saqlang!)
BACKUP_PASSWORD=change-this-strong-backup-password

# ── Tashqi manzil (rclone) ──────────────────────────────────────────
# rclone.conf faylida sozlangan remote nomi (mas. gdrive, s3, b2)
RCLONE_REMOTE=gdrive
# Remote ichidagi papka yo'li
RCLONE_PATH=forex-backups
# Eslatma: rclone.conf faylini shu deploy/ papkada yarating (rclone.conf.example dan).

# ── Ogohlantirish / monitoring (ixtiyoriy) ──────────────────────────
# Qachon xabar berilsin: failure | success | always
NOTIFY_ON=failure
NOTIFY_TELEGRAM_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
# Webhook URL (ixtiyoriy) — har zaxira natijasi shu manzilga POST qilinadi
NOTIFY_WEBHOOK_URL=
# Heartbeat (mas. healthchecks.io URL) — zaxira muvaffaqiyatli bo'lsa ping yuboradi
HEARTBEAT_URL=

# ── Email (SMTP) ogohlantirish (ixtiyoriy) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
