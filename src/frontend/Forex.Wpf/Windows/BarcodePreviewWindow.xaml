<Window
    x:Class="Forex.Wpf.Windows.BarcodePreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Barkod — chop etish"
    Width="760"
    SizeToContent="Height"
    Background="{DynamicResource PrimaryBackground}"
    TextElement.Foreground="{DynamicResource InkPrimary}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding PrintCommand}" />
    </Window.InputBindings>

    <Border Margin="18" Padding="26" Background="{DynamicResource SurfaceCard}" CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="24"
                    FontWeight="Bold"
                    Text="{Binding Title}"
                    TextWrapping="Wrap" />

                <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                    <Border Padding="10,3" Background="{DynamicResource AccentSoft}" CornerRadius="8">
                        <TextBlock FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Accent}" Text="{Binding Size}" />
                    </Border>
                    <Border Margin="8,0,0,0" Padding="10,3" Background="{DynamicResource SuccessSoft}" CornerRadius="8">
                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Success}" Text="{Binding UnitLabel}" />
                    </Border>
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource InkSecondary}"
                        Text="{Binding Pairs, StringFormat={}{0} juft}" />
                </StackPanel>

                <!--  Birlik tanlash (agar to'plam barkodi ham bo'lsa)  -->
                <ListBox
                    Margin="0,0,0,14"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Units}"
                    Padding="0"
                    SelectedItem="{Binding SelectedUnit}"
                    Visibility="{Binding HasMultipleUnits, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,8,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            x:Name="chip"
                                            Padding="16,7"
                                            Background="{DynamicResource SurfaceMuted}"
                                            BorderBrush="{DynamicResource HairlineBorder}"
                                            BorderThickness="1"
                                            CornerRadius="9">
                                            <TextBlock x:Name="txt" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="{Binding}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="chip" Property="Background" Value="{DynamicResource Accent}" />
                                                <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource OnAccent}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Border
                    Padding="12,10"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource HairlineBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <Image
                            Width="300"
                            Height="80"
                            Source="{Binding BarcodeImage}"
                            Stretch="Fill" />
                        <TextBlock
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            FontFamily="Consolas"
                            FontSize="14"
                            Foreground="{DynamicResource InkPrimary}"
                            Text="{Binding Barcode}" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Height="44"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="46" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="0"
                                MinWidth="0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DecrementCopiesCommand}"
                                Content="−"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{DynamicResource InkSecondary}" />
                            <TextBox
                                Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Foreground="{DynamicResource InkPrimary}"
                                Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="2"
                                MinWidth="0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding IncrementCopiesCommand}"
                                Content="+"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{DynamicResource InkSecondary}" />
                        </Grid>
                    </Border>

                    <Button
                        Grid.Column="1"
                        Height="44"
                        Margin="12,0,0,0"
                        md:ButtonAssist.CornerRadius="9"
                        md:ElevationAssist.Elevation="Dp2"
                        Background="{DynamicResource SuccessStrong}"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="{DynamicResource OnAccent}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="20" Height="20" VerticalAlignment="Center" Kind="Printer" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="Chop etish (Enter)" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <Border
                Grid.Column="2"
                Width="240"
                Height="240"
                VerticalAlignment="Center"
                Background="{DynamicResource SurfaceMuted}"
                CornerRadius="8">
                <Image Source="{Binding ImagePath, Converter={StaticResource ImageResolver}}" Stretch="Uniform" />
            </Border>
        </Grid>
    </Border>
</Window>
