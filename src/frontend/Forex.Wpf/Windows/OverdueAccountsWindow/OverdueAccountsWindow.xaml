<Window x:Class="Forex.Wpf.Windows.OverdueAccountsWindow.OverdueAccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Qarzdor Mijozlar"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Width="860" Height="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfacePage}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Margin="2,0,2,14" Orientation="Horizontal">
            <Border
                Width="42" Height="42"
                Background="#FDECEA"
                CornerRadius="11">
                <md:PackIcon
                    Width="24" Height="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="#D32F2F"
                    Kind="CalendarAlert" />
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{DynamicResource InkPrimary}"
                    Text="To'lov muddati o'tgan mijozlar" />
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource InkFaint}"
                    Text="Qarzdorlik va to'lash muddatlarini boshqaring" />
            </StackPanel>
        </StackPanel>

        <!--  Filter bar  -->
        <Border Grid.Row="1"
                Padding="14,12"
                Background="{DynamicResource SurfaceMuted}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="Medium"
                        Foreground="{DynamicResource InkMuted}"
                        Text="Mijoz" />
                    <Border Height="34"
                            BorderBrush="{DynamicResource HairlineBorder}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ComboBox x:Name="cbxCustomer"
                                  Width="250"
                                  Padding="8,0"
                                  VerticalContentAlignment="Center"
                                  Background="{DynamicResource SurfaceCard}"
                                  BorderThickness="0"
                                  DisplayMemberPath="Name"
                                  FontSize="14"
                                  IsEditable="True"
                                  ItemsSource="{Binding AviableUsers}"
                                  SelectedItem="{Binding SelectedCustomer}" />
                    </Border>
                    <Button Height="34" Margin="10,0,0,0" Padding="14,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="{DynamicResource SurfaceCard}" BorderBrush="{DynamicResource HairlineBorder}" BorderThickness="1"
                            Command="{Binding ClearFilterCommand}"
                            Foreground="{DynamicResource InkSecondary}" ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button Height="34" Margin="5,0" Padding="12,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="#1976D2" BorderThickness="0"
                            Command="{Binding PreviewCommand}"
                            Foreground="White" ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button Height="34" Margin="5,0" Padding="12,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="#00897B" BorderThickness="0"
                            Command="{Binding PrintCommand}"
                            Foreground="White" ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button Height="34" Margin="5,0,0,0" Padding="12,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="#15803D" BorderThickness="0"
                            Command="{Binding ExportToExcelCommand}"
                            Foreground="White" ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid Grid.Row="2"
                  Margin="0,14,0,0"
                  AutoGenerateColumns="False"
                  Background="{DynamicResource SurfaceCard}"
                  BorderBrush="{DynamicResource HairlineBorder}"
                  BorderThickness="1"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  ColumnHeaderHeight="42"
                  FontSize="14"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding AviableUserAccounts}"
                  RowHeaderWidth="0"
                  RowHeight="40"
                  SelectionMode="Single">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
                    <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <DataGridTextColumn Header="Mijoz"
                                    Binding="{Binding User.Name}"
                                    Width="*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="10,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Telefon"
                                    Binding="{Binding User.Phone}"
                                    Width="160"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Qarzdorlik summasi"
                                    Binding="{Binding Balance, StringFormat=N2}"
                                    Width="0.8*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,12,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#D32F2F"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="To'lash muddati" Width="0.8*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding DueDateString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewTextInput="DueDate_PreviewTextInput"
                                     GotFocus="DueDate_GotFocus"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Izoh" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Description}"
                                       TextWrapping="Wrap"
                                       Padding="10,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalContentAlignment="Left"
                                     VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Saqlash" Width="90">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="#E9F8EE"
                                    Foreground="#15803D"
                                    Style="{StaticResource GridActionButton}"
                                    ToolTip="Saqlash">
                                <md:PackIcon Width="16" Height="16" Kind="ContentSave" />
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</Window>
