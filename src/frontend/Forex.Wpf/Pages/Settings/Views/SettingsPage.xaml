<Page
    x:Name="RootPage"
    x:Class="Forex.Wpf.Pages.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Pages.Settings.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Forex.Wpf.Pages.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="SettingsPage"
    Background="{DynamicResource SurfacePage}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Margin="2,0,2,12">
            <StackPanel Orientation="Horizontal">
                <Border
                    Width="42"
                    Height="42"
                    Background="#E8EDFB"
                    CornerRadius="11">
                    <md:PackIcon
                        Width="24"
                        Height="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="#3B5BDB"
                        Kind="CogOutline" />
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{DynamicResource InkPrimary}"
                        Text="Sozlamalar" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource InkFaint}"
                        Text="Mahsulotlar, valyutalar, o'lchov birliklari va server" />
                </StackPanel>
            </StackPanel>

            <Button
                x:Name="btnBack"
                Height="34"
                Padding="14,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                md:ButtonAssist.CornerRadius="9"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                Click="BtnBack_Click"
                Foreground="{DynamicResource InkSecondary}"
                ToolTip="Orqaga (Esc)">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="ArrowLeft" />
                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Orqaga" />
                </StackPanel>
            </Button>
        </Grid>

        <!--  Tabs  -->
        <md:Card
            Grid.Row="1"
            Padding="0"
            md:ElevationAssist.Elevation="Dp2"
            UniformCornerRadius="14">
            <TabControl
                x:Name="tabControl"
                Background="{DynamicResource SurfaceMuted}"
                FontSize="15"
                FontWeight="Medium"
                TabStripPlacement="Top">

                <TabItem Header="Mahsulotlar">
                    <controls:ProductSettingsControl />
                </TabItem>

                <TabItem Header="Valyutalar">
                    <controls:CurrencySettingsControl />
                </TabItem>

                <TabItem Header="O'lchov birliklari">
                    <controls:UnitMeasureSettingsControl />
                </TabItem>

                <TabItem Header="Server">
                    <controls:ServerSettingsControl />
                </TabItem>

                <TabItem Header="Ko'rinish">
                    <controls:AppearanceSettingsControl />
                </TabItem>

                <TabItem Header="Printer">
                    <controls:PrinterSettingsControl />
                </TabItem>
            </TabControl>
        </md:Card>
    </Grid>
</Page>
