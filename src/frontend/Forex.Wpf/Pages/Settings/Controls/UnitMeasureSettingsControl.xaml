<UserControl x:Class="Forex.Wpf.Pages.Settings.Controls.UnitMeasureSettingsControl"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:Forex.Wpf.Pages.Settings.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="CheckBox" x:Key="PersistentCheckBoxStyle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource InkFaint}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="4"
                                    Width="18" Height="18"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <Path x:Name="CheckMark"
                                  Data="M0,4 L2,6 L6,0"
                                  Stroke="{DynamicResource Accent}"
                                  StrokeThickness="2"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RadioDotStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse x:Name="Outer" Width="18" Height="18"
                                     Stroke="{DynamicResource InkFaint}" StrokeThickness="1.5" Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse x:Name="Inner" Width="9" Height="9" Fill="{DynamicResource Accent}"
                                     Visibility="Collapsed"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Inner" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource BorderStrong}" />
                                <Setter TargetName="Inner" Property="Fill" Value="{DynamicResource BorderStrong}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CellInput" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource InkPrimary}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource GridHeaderBg}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,10"
                Margin="0,0,17,0"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Odatiy" Grid.Column="1" Style="{StaticResource HeaderText}" />
                <TextBlock Text="Faol" Grid.Column="2" Style="{StaticResource HeaderText}" />
                <TextBlock Text="Nomi" Grid.Column="3" Style="{StaticResource HeaderText}" />
                <TextBlock Text="Belgilanish" Grid.Column="4" Style="{StaticResource HeaderText}" />
                <TextBlock Text="Batafsil" Grid.Column="5" Style="{StaticResource HeaderText}" />
                <TextBlock Text="Amallar" Grid.Column="6" Style="{StaticResource HeaderText}" />
            </Grid>
        </Border>

        <!-- Scrollable o'lchov birliklari ro'yxati -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,6">
            <ItemsControl ItemsSource="{Binding UnitMeasures}"
                          AllowDrop="True"
                          Drop="ItemsControl_Drop">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource HairlineBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12,8"
                                Margin="0,5"
                                Background="{DynamicResource SurfaceCard}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="5*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>

                                <fa:IconImage Icon="GripVertical"
                                              Width="15" Height="15"
                                              Cursor="SizeAll"
                                              Foreground="{DynamicResource InkFaint}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="2"
                                              MouseDown="DragHandle_MouseDown"
                                              MouseMove="DragHandle_MouseMove"
                                              MouseUp="DragHandle_MouseUp"
                                              ToolTip="Joyini o'zgartirish" />

                                <RadioButton GroupName="DefaultUnitMeasure"
                                             IsChecked="{Binding IsDefault}"
                                             IsEnabled="{Binding IsActive}"
                                             ToolTip="Default o'lchov birligi"
                                             Grid.Column="1"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource RadioDotStyle}" />

                                <CheckBox IsChecked="{Binding IsActive}"
                                          Style="{StaticResource PersistentCheckBoxStyle}"
                                          Grid.Column="2"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />

                                <TextBox Text="{Binding Name}" Grid.Column="3" Style="{StaticResource CellInput}" />
                                <TextBox Text="{Binding Symbol}" Grid.Column="4" Style="{StaticResource CellInput}" />
                                <TextBox Text="{Binding Description}" Grid.Column="5" Style="{StaticResource CellInput}" HorizontalContentAlignment="Left" Padding="6,0" />

                                <Button Grid.Column="6"
                                        Height="30"
                                        Padding="10,0"
                                        HorizontalAlignment="Center"
                                        md:ButtonAssist.CornerRadius="8"
                                        Background="{DynamicResource DangerSoft}"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource Danger}"
                                        Command="{Binding DataContext.RemoveUnitMeasureCommand, ElementName=RootControl}"
                                        CommandParameter="{Binding}"
                                        ToolTip="O'lchov birligini o'chirish">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Width="15" Height="15" VerticalAlignment="Center" Kind="DeleteOutline" />
                                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="O'chirish" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Qo'shish va Saqlash tugmalari -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0">
            <Button Command="{Binding AddUnitMeasureCommand}"
                    Height="38" Padding="18,0"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource Accent}" BorderThickness="0"
                    Foreground="{DynamicResource OnAccent}" FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="Plus" />
                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Birlik qo'shish" />
                </StackPanel>
            </Button>

            <Button Command="{Binding SaveUnitMeasuresCommand}"
                    Height="38" Padding="22,0" Margin="12,0,0,0"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource SuccessStrong}" BorderThickness="0"
                    Foreground="{DynamicResource OnAccent}" FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="ContentSave" />
                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Saqlash" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
