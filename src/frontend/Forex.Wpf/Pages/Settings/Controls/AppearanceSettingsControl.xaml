<UserControl x:Class="Forex.Wpf.Pages.Settings.Controls.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:uc="clr-namespace:Forex.Wpf.Resources.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
            <Setter Property="Margin" Value="4,0,0,8" />
        </Style>
        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkPrimary}" />
        </Style>
        <Style x:Key="RowDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource InkFaint}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Width="660"
            Margin="24"
            HorizontalAlignment="Center">

            <!--  Theme  -->
            <TextBlock Margin="0,0,0,8" Style="{StaticResource SectionTitle}" Text="MAVZU" />
            <Border
                Padding="18,14"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40" Height="40"
                        Background="{DynamicResource SurfaceChip}"
                        CornerRadius="10">
                        <md:PackIcon
                            Width="22" Height="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource InkSecondary}"
                            Kind="WeatherNight" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource RowTitle}" Text="Tungi rejim" />
                        <TextBlock Style="{StaticResource RowDesc}" Text="Yumshoq tungi ranglar — ko'zga qulay" />
                    </StackPanel>
                    <ToggleButton
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        IsChecked="{Binding DarkTheme, Mode=TwoWay}"
                        Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                </Grid>
            </Border>

            <!--  Printer  -->
            <TextBlock Margin="0,18,0,8" Style="{StaticResource SectionTitle}" Text="YORLIQ PRINTERI" />
            <Border
                Padding="18,16"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="40" Height="40"
                            Background="{DynamicResource SurfaceChip}"
                            CornerRadius="10">
                            <md:PackIcon
                                Width="22" Height="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Accent}"
                                Kind="Printer" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource RowTitle}" Text="Yorliq printeri" />
                            <TextBlock Style="{StaticResource RowDesc}" Text="Barkod yorliqlari shu printerga chiqariladi (60×40 mm)" />
                        </StackPanel>
                    </StackPanel>
                    <uc:FloatingComboBox
                        x:Name="printerCombo"
                        Margin="0,18,0,4"
                        Label="Printer tanlang"
                        SelectedItem="{Binding LabelPrinter, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!--  Dashboard components  -->
            <TextBlock Margin="0,0,0,8" Style="{StaticResource SectionTitle}" Text="BOSH SAHIFA KOMPONENTLARI" />
            <Border
                Padding="6,4"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel>
                    <Grid Margin="12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <md:PackIcon Width="22" Height="22" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" Kind="CardsOutline" />
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource RowTitle}" Text="Statistik kartalar" />
                            <TextBlock Style="{StaticResource RowDesc}" Text="Bugungi/haftalik savdo, juftlar soni" />
                        </StackPanel>
                        <ToggleButton Grid.Column="2" VerticalAlignment="Center" IsChecked="{Binding ShowDashboardStats, Mode=TwoWay}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>
                    <Separator Margin="12,0" Background="{DynamicResource SurfaceMuted}" />

                    <Grid Margin="12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <md:PackIcon Width="22" Height="22" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" Kind="ChartLine" />
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource RowTitle}" Text="Savdo dinamikasi" />
                            <TextBlock Style="{StaticResource RowDesc}" Text="So'nggi 7 kunlik chiziqli grafik" />
                        </StackPanel>
                        <ToggleButton Grid.Column="2" VerticalAlignment="Center" IsChecked="{Binding ShowSalesTrend, Mode=TwoWay}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>
                    <Separator Margin="12,0" Background="{DynamicResource SurfaceMuted}" />

                    <Grid Margin="12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <md:PackIcon Width="22" Height="22" VerticalAlignment="Center" Foreground="{DynamicResource IconViolet}" Kind="AccountStar" />
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource RowTitle}" Text="Top mijozlar" />
                            <TextBlock Style="{StaticResource RowDesc}" Text="Eng faol mijozlar diagrammasi" />
                        </StackPanel>
                        <ToggleButton Grid.Column="2" VerticalAlignment="Center" IsChecked="{Binding ShowTopCustomers, Mode=TwoWay}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>
                    <Separator Margin="12,0" Background="{DynamicResource SurfaceMuted}" />

                    <Grid Margin="12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <md:PackIcon Width="22" Height="22" VerticalAlignment="Center" Foreground="{DynamicResource Success}" Kind="ShoeSneaker" />
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource RowTitle}" Text="Top mahsulotlar" />
                            <TextBlock Style="{StaticResource RowDesc}" Text="Eng ko'p sotilgan mahsulotlar" />
                        </StackPanel>
                        <ToggleButton Grid.Column="2" VerticalAlignment="Center" IsChecked="{Binding ShowTopProducts, Mode=TwoWay}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
