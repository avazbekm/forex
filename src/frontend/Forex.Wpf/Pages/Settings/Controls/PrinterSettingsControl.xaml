<UserControl x:Class="Forex.Wpf.Pages.Settings.Controls.PrinterSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
            <Setter Property="Margin" Value="4,0,0,8" />
        </Style>
        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkPrimary}" />
        </Style>
        <Style x:Key="RowDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource InkFaint}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Width="660"
            Margin="24"
            HorizontalAlignment="Center">

            <TextBlock Margin="0,0,0,8" Style="{StaticResource SectionTitle}" Text="YORLIQ (ETIKETKA) PRINTERI" />
            <Border
                Padding="18,16"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40" Height="40"
                        Background="{DynamicResource SurfaceChip}"
                        CornerRadius="10">
                        <md:PackIcon
                            Width="22" Height="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#3B5BDB"
                            Kind="Printer" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource RowTitle}" Text="Yorliq printeri" />
                        <TextBlock Style="{StaticResource RowDesc}" Text="Barkod yorliqlari shu printerga chiqariladi (60×40 mm)" />
                    </StackPanel>
                    <ComboBox
                        x:Name="printerCombo"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        md:HintAssist.Hint="Printer tanlang"
                        SelectedItem="{Binding LabelPrinter, Mode=TwoWay}"
                        Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
