<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.FinishedStockReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:charts="clr-namespace:Forex.Wpf.Resources.Charts"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="{DynamicResource SurfaceCard}">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14" Background="{DynamicResource SurfaceCard}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Filter bar  -->
        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="{DynamicResource SurfaceMuted}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Qidirish" />
                    <Border
                        Height="34"
                        Padding="8,0"
                        Background="{DynamicResource SurfaceCard}"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource InkFaint}"
                                Kind="Magnify" />
                            <TextBox
                                x:Name="txtSearch"
                                Width="240"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                md:HintAssist.Hint="Kod yoki nom bo'yicha qidirish..."
                                BorderThickness="0"
                                FontSize="14"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        x:Name="btnLoad"
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding LoadCommand}"
                        Foreground="White"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}"
                        ToolTip="Yuklash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Refresh" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Yuklash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        x:Name="btnClear"
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource SurfaceCard}"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="{DynamicResource InkSecondary}"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    Grid.Column="3"
                    Margin="0,0,12,0"
                    Padding="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource SurfaceChip}"
                    CornerRadius="9">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnTableView"
                            Click="TableView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Jadval">
                            <md:PackIcon Width="18" Height="18" Kind="TableLarge" />
                        </Button>
                        <Button
                            x:Name="btnChartView"
                            Click="ChartView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Diagramma">
                            <md:PackIcon Width="18" Height="18" Kind="ChartBar" />
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnPreview"
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button
                        x:Name="btnPrint"
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button
                        x:Name="btnExport"
                        Height="34"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#15803D"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid
            x:Name="grid"
            Grid.Row="1"
            Margin="0,14,0,0"
            AutoGenerateColumns="False"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ColumnHeaderHeight="42"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
            IsReadOnly="True"
            ItemsSource="{Binding PagedItems}"
            RowHeight="38"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
                    <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="50" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="80" Binding="{Binding Code}" Header="Kodi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="2*" Binding="{Binding Name}" Header="Nomi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="Padding" Value="6,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding Type}" Header="Razmer">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="80" Binding="{Binding BundleCount}" Header="Qop soni">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding BundleItemCount, StringFormat=N0}" Header="Donasi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding TotalCount, StringFormat=N0}" Header="Jami">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,10,0" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding UnitPrice, StringFormat=N2}" Header="Narxi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,10,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="1.3*" Binding="{Binding TotalAmount, StringFormat=N2}" Header="Umumiy summa">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,10,0" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#1B7A3E" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!--  Chart  -->
        <Border
            x:Name="chartPanel"
            Grid.Row="1"
            Margin="0,14,0,0"
            Padding="18,16"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <md:PackIcon
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Foreground="#1B7A3E"
                            Kind="ChartBar" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource InkPrimary}"
                            Text="Qoldiqlar reytingi" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Border
                            Padding="3"
                            Background="{DynamicResource SurfaceChip}"
                            CornerRadius="9">
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    x:Name="btnMetricSum"
                                    Width="64"
                                    Click="MetricSum_Click"
                                    Style="{StaticResource ViewToggleButton}"
                                    ToolTip="Summa bo'yicha">
                                    <TextBlock FontSize="12.5" Text="Summa" />
                                </Button>
                                <Button
                                    x:Name="btnMetricCount"
                                    Width="56"
                                    Click="MetricCount_Click"
                                    Style="{StaticResource ViewToggleButton}"
                                    ToolTip="Soni bo'yicha">
                                    <TextBlock FontSize="12.5" Text="Soni" />
                                </Button>
                            </StackPanel>
                        </Border>
                        <Button
                            x:Name="btnStockSort"
                            Margin="10,0,0,0"
                            Click="StockSort_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Tartib (o'sish / kamayish)">
                            <md:PackIcon
                                x:Name="icoStockSort"
                                Width="18"
                                Height="18"
                                Kind="SortDescending" />
                        </Button>
                    </StackPanel>
                </Grid>
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <charts:BarChart
                        VerticalAlignment="Top"
                        Accent="#1B7A3E"
                        MaxValue="{Binding ChartMax}"
                        Points="{Binding StockChart}"
                        RowHeight="34" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  Totals + Pager  -->
        <Border
            Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12,10"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Rows="1">
                    <controls:StatCard
                        Accent="#3949AB"
                        CardBackground="#EEF2FF"
                        Title="Mahsulotlar"
                        TitleBrush="#6470B0"
                        Value="{Binding TotalCount}" />
                    <controls:StatCard
                        Accent="#A66A12"
                        CardBackground="#FFF6E6"
                        Title="Jami dona"
                        TitleBrush="#B7791F"
                        Value="{Binding SummaryQty, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="#1B7A3E"
                        CardBackground="#E9F8EE"
                        Title="Umumiy summa (so'm)"
                        TitleBrush="#2E8B57"
                        Value="{Binding TotalAmount, StringFormat=N2}" />
                </UniformGrid>

                <controls:Pager
                    Grid.Column="1"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    TotalPages="{Binding TotalPages}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
