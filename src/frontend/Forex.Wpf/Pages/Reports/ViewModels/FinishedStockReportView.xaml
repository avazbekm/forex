<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.FinishedStockReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="Kodi" />

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal">
                    <Border
                        Height="30"
                        BorderBrush="#CCCCCC"
                        BorderThickness="2"
                        CornerRadius="4">
                        <ComboBox
                            Name="cbxProductCode"
                            Width="175"
                            Padding="3"
                            BorderThickness="0"
                            FontSize="14"
                            IsEditable="True"
                            ItemsSource="{Binding AvailableCodes}"
                            SelectedItem="{Binding SelectedCode}" />
                    </Border>

                    <Button
                        x:Name="btnLoad"
                        Width="90"
                        Height="29"
                        Margin="10,0,0,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding LoadCommand}"
                        Content="Yuklash"
                        Foreground="White" />
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Text="Nomi" />
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Height="30"
                    BorderBrush="#CCCCCC"
                    BorderThickness="2"
                    CornerRadius="4">
                    <ComboBox
                        x:Name="cbxProductName"
                        Width="275"
                        Padding="3"
                        BorderThickness="0"
                        FontSize="14"
                        IsEditable="True"
                        ItemsSource="{Binding AvailableNames}"
                        SelectedItem="{Binding SelectedName}" />
                </Border>
            </Grid>

            <StackPanel
                Grid.Column="1"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Button
                    x:Name="btnPreview"
                    Height="29"
                    Margin="0,2"
                    md:ButtonAssist.CornerRadius="4"
                    Background="#1976D2"
                    BorderThickness="0"
                    Command="{Binding PreviewCommand}"
                    Content="Ko‘rish"
                    Foreground="White" />
                <Button
                    x:Name="btnClear"
                    Height="29"
                    Margin="0,2"
                    md:ButtonAssist.CornerRadius="4"
                    Background="#3949AB"
                    BorderThickness="0"
                    Command="{Binding ClearFilterCommand}"
                    Content="Tozalash"
                    Foreground="White" />
            </StackPanel>
            <StackPanel
                Grid.Column="2"
                Margin="10,0"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <Button
                    x:Name="btnPrint"
                    Height="29"
                    Margin="0,2"
                    md:ButtonAssist.CornerRadius="4"
                    Background="#00897B"
                    BorderThickness="0"
                    Command="{Binding PrintCommand}"
                    Content="Pechat"
                    Foreground="White" />
                <Button
                    x:Name="btnExport"
                    Height="29"
                    Margin="0,2"
                    md:ButtonAssist.CornerRadius="4"
                    Background="#2E7D32"
                    BorderThickness="0"
                    Command="{Binding ExportToExcelCommand}"
                    Content="Excel"
                    Foreground="White" />
            </StackPanel>
        </Grid>

        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            BorderBrush="LightGray"
            BorderThickness="2"
            FontSize="14"
            IsReadOnly="True"
            ItemsSource="{Binding Items}"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <!--  HEADERLARNI O‘RTAGA OLISH  -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--  Kodi — qiymati o‘rtada  -->
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Code}"
                    Header="Kodi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Nomi — chapda  -->
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Nomi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Razmer — o‘rtada  -->
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Type}"
                    Header="Razmer">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Qop soni — chapda  -->
                <DataGridTextColumn
                    Width="0.7*"
                    Binding="{Binding BundleCount}"
                    Header="Qop soni">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Qopdagi soni — o‘rtada  -->
                <DataGridTextColumn
                    Width="0.7*"
                    Binding="{Binding BundleItemCount, StringFormat=N0}"
                    Header="Donasi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <!--  Jami — o‘ngda  -->
                <DataGridTextColumn
                    Width="0.5*"
                    Binding="{Binding TotalCount, StringFormat=N0}"
                    Header="Jami">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Narxi — o‘ngda  -->
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding UnitPrice, StringFormat=N2}"
                    Header="Narxi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Umumiy summa — o‘ngda  -->
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding TotalAmount, StringFormat=N2}"
                    Header="Umumiy summa">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>