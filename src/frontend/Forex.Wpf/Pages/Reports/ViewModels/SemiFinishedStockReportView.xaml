<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.SemiFinishedStockReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">
    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter Panel -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#FAFAFA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Kod va Nomi filtrlari -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontSize="12"
                            Foreground="#666"
                            Text="Yarim tayyor mahsulot" />
                        <Border
                            Height="36"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ComboBox
                                x:Name="cbxSemiProduct"
                                Width="250"
                                Padding="8,0"
                                VerticalContentAlignment="Center"
                                BorderThickness="0"
                                DisplayMemberPath="Name"
                                FontSize="14"
                                IsEditable="True"
                                ItemsSource="{Binding AvailableSemiProducts}"
                                SelectedItem="{Binding SelectedSemiProduct, Mode=TwoWay}" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Tugmalar -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Button
                        x:Name="btnPreview"
                        Width="90"
                        Height="36"
                        Margin="0,0,10,0"
                        md:ButtonAssist.CornerRadius="6"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding RefreshCommand}"
                        Content="Ko'rish"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White" />
                    <Button
                        x:Name="btnClear"
                        Width="90"
                        Height="36"
                        Margin="0,0,10,0"
                        md:ButtonAssist.CornerRadius="6"
                        Background="#607D8B"
                        BorderThickness="0"
                        Command="{Binding ClearFilterCommand}"
                        Content="Tozalash"
                        FontSize="14"
                        Foreground="White" />
                    <Button
                        x:Name="btnPrint"
                        Width="90"
                        Height="36"
                        Margin="0,0,10,0"
                        md:ButtonAssist.CornerRadius="6"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Content="Pechat"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White" />
                    <Button
                        x:Name="btnExport"
                        Width="90"
                        Height="36"
                        md:ButtonAssist.CornerRadius="6"
                        Background="#2E7D32"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Content="Excel"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F8F9FA"
            AutoGenerateColumns="False"
            BorderBrush="LightGray"
            BorderThickness="1"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            ItemsSource="{Binding Items}"
            RowHeight="42"
            VirtualizingStackPanel.VirtualizationMode="Standard">
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Background" Value="#E3F2FD" />
                    <Setter Property="Padding" Value="8" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="50" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Nomi" />
                    
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding Type}"
                    Header="Razmer">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding BundleItemCount, StringFormat=N0}"
                    Header="Donasi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding BundleCount, StringFormat=N0}"
                    Header="Qop soni">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding UnitMeasure}"
                    Header="O'lchov">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding TotalCount, StringFormat=N0}"
                    Header="Jami">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#1565C0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding PurchasePrice, StringFormat=N2}"
                    Header="Kelish narxi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding ExpensePerItem, StringFormat=N2}"
                    Header="Harajatlar">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#C62828" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding CostPrice, StringFormat=N2}"
                    Header="Tannarxi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="130"
                    Binding="{Binding TotalAmount, StringFormat=N2}"
                    Header="Umumiy summa">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Foreground" Value="#1B5E20" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer totals -->
        <Border
            Grid.Row="2"
            Margin="0,10,0,0"
            Padding="15,10"
            Background="#E8F5E8"
            BorderBrush="#C8E6C9"
            BorderThickness="1"
            CornerRadius="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock
                    Margin="0,0,30,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="{Binding Items.Count, StringFormat='Jami yozuvlar: {0} ta'}" />
                <TextBlock
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="#1B5E20"
                    Text="{Binding TotalSum, StringFormat='Umumiy summa: {0:N2}'}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
