<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.DebtorCreditorReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">

    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#7A8699" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Filter bar  -->
        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="#F8FAFD"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Mijozni izlash" />
                    <Border
                        Height="34"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBox
                            x:Name="txtSearch"
                            Width="260"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding LoadCommand}"
                        Foreground="White"
                        ToolTip="Yuklash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Refresh" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Yuklash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        x:Name="btnClear"
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="White"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="#475467"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnPreview"
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button
                        x:Name="btnPrint"
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button
                        x:Name="btnExport"
                        Height="34"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#15803D"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid
            Grid.Row="1"
            Margin="0,14,0,0"
            AutoGenerateColumns="False"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ColumnHeaderHeight="42"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="#F0F2F6"
            IsReadOnly="True"
            ItemsSource="{Binding PagedItems}"
            RowHeight="40"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.Resources>
                <Style x:Key="CenterCell" TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F4F7FC" />
                    <Setter Property="Foreground" Value="#5A6477" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Mijoz">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="170"
                    Binding="{Binding Phone}"
                    Header="Telefon">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextTrimming" Value="None" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding Address}"
                    Header="Manzil">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding DebtorAmount, StringFormat=N2}"
                    Header="Debit (Bizga qarzi)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#2E7D32" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding CreditorAmount, StringFormat=N2}"
                    Header="Kredit (Bizning qarzimiz)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#D32F2F" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding CurrencyCode}"
                    ElementStyle="{StaticResource CenterCell}"
                    Header="Valyuta" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Totals + Pager  -->
        <Border
            Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12,10"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Rows="1">
                    <controls:StatCard
                        Accent="#3949AB"
                        CardBackground="#EEF2FF"
                        Title="Yozuvlar"
                        TitleBrush="#6470B0"
                        Value="{Binding TotalCount}" />
                    <controls:StatCard
                        Accent="#1B7A3E"
                        Caption="{Binding DebtorBreakdown}"
                        CardBackground="#E9F8EE"
                        Title="Debitor (so'm)"
                        TitleBrush="#2E8B57"
                        Value="{Binding SummaryDebtor, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="#C0392B"
                        Caption="{Binding CreditorBreakdown}"
                        CardBackground="#FDECEA"
                        Title="Kreditor (so'm)"
                        TitleBrush="#C0564B"
                        Value="{Binding SummaryCreditor, StringFormat=N0}" />
                </UniformGrid>

                <controls:Pager
                    Grid.Column="1"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    TotalPages="{Binding TotalPages}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
