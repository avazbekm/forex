<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.DebtorCreditorReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:charts="clr-namespace:Forex.Wpf.Resources.Charts"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="{DynamicResource SurfaceCard}">

    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14" Background="{DynamicResource SurfaceCard}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Filter bar  -->
        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="{DynamicResource SurfaceMuted}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Mijozni izlash" />
                    <Border
                        Height="34"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBox
                            x:Name="txtSearch"
                            Width="260"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            Foreground="{DynamicResource InkPrimary}"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource IconViolet}"
                        BorderThickness="0"
                        Command="{Binding LoadCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        ToolTip="Yuklash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Refresh" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Yuklash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        x:Name="btnClear"
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource SurfaceCard}"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="{DynamicResource InkSecondary}"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    Grid.Column="3"
                    Margin="0,0,12,0"
                    Padding="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource SurfaceChip}"
                    CornerRadius="9">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnTableView"
                            Click="TableView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Jadval">
                            <md:PackIcon Width="18" Height="18" Kind="TableLarge" />
                        </Button>
                        <Button
                            x:Name="btnChartView"
                            Click="ChartView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Diagramma">
                            <md:PackIcon Width="18" Height="18" Kind="ChartBar" />
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnPreview"
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource Accent}"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button
                        x:Name="btnPrint"
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource Teal}"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button
                        x:Name="btnExport"
                        Height="34"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource SuccessStrong}"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid
            x:Name="grid"
            Grid.Row="1"
            Margin="0,14,0,0"
            AutoGenerateColumns="False"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ColumnHeaderHeight="42"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
            IsReadOnly="True"
            ItemsSource="{Binding PagedItems}"
            RowHeight="40"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.Resources>
                <Style x:Key="CenterCell" TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
                    <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Mijoz">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="170"
                    Binding="{Binding Phone}"
                    Header="Telefon">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextTrimming" Value="None" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding Address}"
                    Header="Manzil">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding DebtorAmount, StringFormat=N2}"
                    Header="Debit (Bizga qarzi)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="{DynamicResource Success}" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding CreditorAmount, StringFormat=N2}"
                    Header="Kredit (Bizning qarzimiz)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="{DynamicResource Danger}" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding CurrencyCode}"
                    ElementStyle="{StaticResource CenterCell}"
                    Header="Valyuta" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Chart  -->
        <Border
            x:Name="chartPanel"
            Grid.Row="1"
            Margin="0,14,0,0"
            Padding="18,16"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <md:PackIcon
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource InkSecondary}"
                            Kind="ChartBar" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource InkPrimary}"
                            Text="Qarzdorlik holati (so'm)" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Ellipse
                            Width="11"
                            Height="11"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource Danger}" />
                        <TextBlock
                            Margin="6,0,16,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource InkMuted}"
                            Text="Bizga qarzi" />
                        <Ellipse
                            Width="11"
                            Height="11"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource Success}" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource InkMuted}"
                            Text="Bizning qarzimiz" />
                        <Button
                            x:Name="btnDebtorSort"
                            Margin="14,0,0,0"
                            Click="DebtorSort_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Tartib (o'sish / kamayish)">
                            <md:PackIcon
                                x:Name="icoDebtorSort"
                                Width="18"
                                Height="18"
                                Kind="SortDescending" />
                        </Button>
                    </StackPanel>
                </Grid>
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <charts:BarChart
                        VerticalAlignment="Top"
                        Accent="{DynamicResource SuccessColorValue}"
                        MaxValue="{Binding ChartMax}"
                        Points="{Binding DebtorChart}"
                        RowHeight="34" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  Totals + Pager  -->
        <Border
            Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12,10"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Rows="1">
                    <controls:StatCard
                        Accent="{DynamicResource Accent}"
                        CardBackground="{DynamicResource AccentSoft}"
                        Title="Yozuvlar"
                        TitleBrush="{DynamicResource InkSecondary}"
                        Value="{Binding TotalCount}" />
                    <controls:StatCard
                        Accent="{DynamicResource Success}"
                        Caption="{Binding DebtorBreakdown}"
                        CardBackground="{DynamicResource SuccessSoft}"
                        Title="Debitor (so'm)"
                        TitleBrush="{DynamicResource Success}"
                        Value="{Binding SummaryDebtor, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="{DynamicResource Danger}"
                        Caption="{Binding CreditorBreakdown}"
                        CardBackground="{DynamicResource DangerSoft}"
                        Title="Kreditor (so'm)"
                        TitleBrush="{DynamicResource Danger}"
                        Value="{Binding SummaryCreditor, StringFormat=N0}" />
                </UniformGrid>

                <controls:Pager
                    Grid.Column="1"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    TotalPages="{Binding TotalPages}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
