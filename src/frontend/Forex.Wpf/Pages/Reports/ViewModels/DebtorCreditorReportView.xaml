<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.DebtorCreditorReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">

    <UserControl.Resources>
        <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter Panel -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#FAFAFA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Mijoz Filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontSize="12"
                            Foreground="#666"
                            Text="Mijozni izlash" />
                        <Border
                            Height="36"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBox
                                x:Name="txtSearch"
                                Width="250"
                                Padding="8,6"
                                VerticalContentAlignment="Center"
                                BorderThickness="0"
                                FontSize="14"
                                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <Button
                        x:Name="btnLoad"
                        Height="36"
                        Margin="0,21,0,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding LoadCommand}"
                        Foreground="White">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Refresh" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Yuklash" />
                        </StackPanel>
                    </Button>
                    
                     <Button
                        x:Name="btnClear"
                        Height="36"
                        Margin="10,21,0,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#78909C"
                        BorderThickness="0"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="White"
                        ToolTip="Filterni tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="FilterRemove" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Actions -->
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom">
                    <Button
                        x:Name="btnPreview"
                        Height="36"
                        Margin="5,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Eye" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Ko'rish" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="btnPrint"
                        Height="36"
                        Margin="5,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Printer" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Pechat" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="btnExport"
                        Height="36"
                        Margin="5,0,0,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#2E7D32"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="FileExcel" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Excel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            BorderBrush="LightGray"
            BorderThickness="1"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            ItemsSource="{Binding FilteredItems}"
            RowHeight="42"
            VirtualizingStackPanel.VirtualizationMode="Standard">
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Background" Value="#E3F2FD" />
                    <Setter Property="Padding" Value="8" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Mijoz" />
                    
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding Phone}"
                    ElementStyle="{StaticResource CenterAlignedCellStyle}"
                    Header="Telefon" />
                    
                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding Address}"
                    Header="Manzil" />
                    
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding DebtorAmount, StringFormat=N2}"
                    Header="Debit (Bizga qarzi)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#2E7D32" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding CreditorAmount, StringFormat=N2}"
                    Header="Kredit (Bizning qarzimiz)">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Foreground" Value="#D32F2F" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding CurrencyCode}"
                    ElementStyle="{StaticResource CenterAlignedCellStyle}"
                    Header="Valyuta" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border
            Grid.Row="2"
            Margin="0,10,0,0"
            Padding="15,10"
            Background="#E8F5E8"
            BorderBrush="#C8E6C9"
            BorderThickness="1"
            CornerRadius="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#555"
                    Text="{Binding FilteredItems.Count, StringFormat='Jami yozuvlar: {0} ta'}" />

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="#333"
                    Text="{Binding TotalsSummary}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>