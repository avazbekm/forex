<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.CustomerTurnoverReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:charts="clr-namespace:Forex.Wpf.Resources.Charts"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="{DynamicResource SurfaceCard}">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14" Background="{DynamicResource SurfaceCard}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Filter bar  -->
        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="{DynamicResource SurfaceMuted}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Boshlanish" />
                    <controls:UserCalendar
                        Width="120"
                        Height="34"
                        SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tugash" />
                    <controls:UserCalendar
                        Width="120"
                        Height="34"
                        SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Shaxsni tanlang" />
                    <Border
                        Height="34"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <ComboBox
                            x:Name="cbxCustomer"
                            Width="250"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Style="{StaticResource MaterialDesignComboBox}"
                            md:TextFieldAssist.DecorationVisibility="Collapsed"
                            DisplayMemberPath="Name"
                            FontSize="14"
                            IsEditable="True"
                            ItemsSource="{Binding AvailableCustomers}"
                            SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <Button
                        Height="34"
                        Padding="14,0"
                        HorizontalAlignment="Left"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource SurfaceCard}"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="{DynamicResource InkSecondary}"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    Grid.Column="3"
                    Margin="0,0,12,0"
                    Padding="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource SurfaceChip}"
                    CornerRadius="9">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnTableView"
                            Click="TableView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Jadval">
                            <md:PackIcon Width="18" Height="18" Kind="TableLarge" />
                        </Button>
                        <Button
                            x:Name="btnChartView"
                            Click="ChartView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Diagramma">
                            <md:PackIcon Width="18" Height="18" Kind="ChartLine" />
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource IconViolet}"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource Teal}"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button
                        Height="34"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="{DynamicResource SuccessStrong}"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="{DynamicResource OnAccent}"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid
            x:Name="grid"
            Grid.Row="1"
            Margin="0,14,0,0"
            AutoGenerateColumns="False"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ColumnHeaderHeight="42"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
            IsReadOnly="True"
            ItemsSource="{Binding PagedItems}"
            RowHeight="40"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
                    <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="150" Binding="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}" Header="Sana">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="160" Binding="{Binding Debit, StringFormat=N0}" Header="Chiqim">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="Foreground" Value="{DynamicResource Danger}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="160" Binding="{Binding Credit, StringFormat=N0}" Header="Kirim">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="Foreground" Value="{DynamicResource Success}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Izoh">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!--  Chart  -->
        <Border
            x:Name="chartPanel"
            Grid.Row="1"
            Margin="0,14,0,0"
            Padding="18,16"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource Accent}"
                        Kind="ChartLine" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource InkPrimary}"
                        Text="Kunlik aylanma hajmi" />
                </StackPanel>
                <charts:LineChart
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Data="{Binding TurnoverChart}" />
            </Grid>
        </Border>

        <!--  Totals + Pager  -->
        <Border
            Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12,10"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource HairlineBorder}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Rows="1">
                    <controls:StatCard
                        Accent="{DynamicResource Accent}"
                        CardBackground="{DynamicResource AccentSoft}"
                        Caption="{Binding SettlementCurrencyCode}"
                        Title="Boshlang'ich qoldiq"
                        TitleBrush="{DynamicResource InkSecondary}"
                        Value="{Binding BeginBalance, StringFormat=N2}" />
                    <controls:StatCard
                        Accent="{DynamicResource Danger}"
                        CardBackground="{DynamicResource DangerSoft}"
                        Title="Jami chiqim"
                        TitleBrush="{DynamicResource Danger}"
                        Value="{Binding SummaryDebit, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="{DynamicResource Success}"
                        CardBackground="{DynamicResource SuccessSoft}"
                        Title="Jami kirim"
                        TitleBrush="{DynamicResource Success}"
                        Value="{Binding SummaryCredit, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="{DynamicResource Warning}"
                        CardBackground="{DynamicResource WarningSoft}"
                        Caption="{Binding SettlementCurrencyCode}"
                        Title="Oxirgi qoldiq"
                        TitleBrush="{DynamicResource Warning}"
                        Value="{Binding LastBalance, StringFormat=N2}" />
                </UniformGrid>

                <controls:Pager
                    Grid.Column="1"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    TotalPages="{Binding TotalPages}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
