<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.CustomerTurnoverReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">
    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter Panel -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#FAFAFA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Date Range -->
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontSize="12"
                            Foreground="#666"
                            Text="Sana oralig'i" />
                        <StackPanel Orientation="Horizontal">
                            <controls:UserCalendar
                                Width="120"
                                Height="36"
                                SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                            <TextBlock
                                Margin="8,0"
                                VerticalAlignment="Center"
                                Text="-" />
                            <controls:UserCalendar
                                Width="120"
                                Height="36"
                                SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <!--<StackPanel Margin="0,0,20,0">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontSize="12"
                            Foreground="#666"
                            Text="Aylanma turi" />
                        <Border
                            Height="36"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ComboBox
                                Width="160"
                                Padding="8,0"
                                VerticalContentAlignment="Center"
                                BorderThickness="0"
                                DisplayMemberPath="Text"
                                FontSize="14"
                                ItemsSource="{Binding PartyFilterOptions}"
                                SelectedItem="{Binding SelectedPartyFilterOption, Mode=TwoWay}" />
                        </Border>
                    </StackPanel>-->

                    <!-- Customer -->
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontSize="12"
                            Foreground="#666"
                            Text="Shaxsni tanlang" />
                        <Border
                            Height="36"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ComboBox
                                x:Name="cbxCustomer"
                                Width="250"
                                Padding="8,0"
                                VerticalContentAlignment="Center"
                                BorderThickness="0"
                                DisplayMemberPath="Name"
                                FontSize="14"
                                IsEditable="True"
                                ItemsSource="{Binding AvailableCustomers}"
                                SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}" />
                        </Border>
                    </StackPanel>

                    <!-- Buttons -->
                    <Button
                        x:Name="btnClear"
                        Height="36"
                        Margin="10,21,0,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#78909C"
                        BorderThickness="0"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="White"
                        ToolTip="Filterni tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="FilterRemove" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Actions -->
                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom">
                    <Button
                        x:Name="btnPreview"
                        Height="36"
                        Margin="0,0,5,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White" IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Eye" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Ko‘rish" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="btnPrint"
                        Height="36"
                        Margin="5,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White" IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Printer" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Pechat" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="btnExport"
                        Height="36"
                        Margin="5,0,0,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#2E7D32"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White" IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="FileExcel" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Excel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            BorderBrush="LightGray"
            BorderThickness="1"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            ItemsSource="{Binding Operations}"
            RowHeight="42"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            VirtualizingStackPanel.VirtualizationMode="Standard">
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Background" Value="#E3F2FD" />
                    <Setter Property="Padding" Value="8" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn
                    Width="110"
                    Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                    Header="Sana">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding Debit, StringFormat=N0}"
                    Header="Chiqim">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,12,0" />
                            <Setter Property="Foreground" Value="#C62828" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding Credit, StringFormat=N0}"
                    Header="Kirim">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,12,0" />
                            <Setter Property="Foreground" Value="#1B5E20" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Description}"
                    Header="Izoh">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border
            Grid.Row="2"
            Margin="0,10,0,0"
            Padding="15,10"
            Background="#E8F5E8"
            BorderBrush="#C8E6C9"
            BorderThickness="1"
            CornerRadius="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Boshlang'ich qoldiq -->
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock
                        Margin="0,0,10,0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Boshlang‘ich qoldiq:" />
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#1B5E20"
                        Text="{Binding BeginBalance, StringFormat=N2}" />
                </StackPanel>

                <!-- Oxirgi qoldiq -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Oxirgi qoldiq:" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#B71C1C"
                        Text="{Binding LastBalance, StringFormat=N2}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
