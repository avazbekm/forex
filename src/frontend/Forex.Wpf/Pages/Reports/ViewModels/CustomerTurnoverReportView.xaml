<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.CustomerTurnoverReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#7A8699" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Filter bar  -->
        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="#F8FAFD"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Boshlanish" />
                    <controls:UserCalendar
                        Width="120"
                        Height="34"
                        SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tugash" />
                    <controls:UserCalendar
                        Width="120"
                        Height="34"
                        SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Shaxsni tanlang" />
                    <Border
                        Height="34"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        CornerRadius="6">
                        <ComboBox
                            x:Name="cbxCustomer"
                            Width="250"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            BorderThickness="0"
                            DisplayMemberPath="Name"
                            FontSize="14"
                            IsEditable="True"
                            ItemsSource="{Binding AvailableCustomers}"
                            SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <Button
                        Height="34"
                        Padding="14,0"
                        HorizontalAlignment="Left"
                        md:ButtonAssist.CornerRadius="9"
                        Background="White"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="#475467"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button
                        Height="34"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#15803D"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid
            Grid.Row="1"
            Margin="0,14,0,0"
            AutoGenerateColumns="False"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ColumnHeaderHeight="42"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="#F0F2F6"
            IsReadOnly="True"
            ItemsSource="{Binding PagedItems}"
            RowHeight="40"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F4F7FC" />
                    <Setter Property="Foreground" Value="#5A6477" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="150" Binding="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}" Header="Sana">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="160" Binding="{Binding Debit, StringFormat=N0}" Header="Chiqim">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="Foreground" Value="#C62828" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="160" Binding="{Binding Credit, StringFormat=N0}" Header="Kirim">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,12,0" />
                            <Setter Property="Foreground" Value="#1B5E20" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Izoh">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!--  Totals + Pager  -->
        <Border
            Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12,10"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Rows="1">
                    <controls:StatCard
                        Accent="#3949AB"
                        CardBackground="#EEF2FF"
                        Caption="{Binding SettlementCurrencyCode}"
                        Title="Boshlang'ich qoldiq"
                        TitleBrush="#6470B0"
                        Value="{Binding BeginBalance, StringFormat=N2}" />
                    <controls:StatCard
                        Accent="#C62828"
                        CardBackground="#FDECEA"
                        Title="Jami chiqim"
                        TitleBrush="#C0564B"
                        Value="{Binding SummaryDebit, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="#1B7A3E"
                        CardBackground="#E9F8EE"
                        Title="Jami kirim"
                        TitleBrush="#2E8B57"
                        Value="{Binding SummaryCredit, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="#A66A12"
                        CardBackground="#FFF6E6"
                        Caption="{Binding SettlementCurrencyCode}"
                        Title="Oxirgi qoldiq"
                        TitleBrush="#B7791F"
                        Value="{Binding LastBalance, StringFormat=N2}" />
                </UniformGrid>

                <controls:Pager
                    Grid.Column="1"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    TotalPages="{Binding TotalPages}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
