<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.SalesHistoryReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="15,10"
            Background="#FAFAFA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <controls:FloatingImageComboBox
                        x:Name="cbxCustomer"
                        Width="200"
                        Height="36"
                        IsSearchEnabled="True"
                        ItemsSource="{Binding AvailableCustomers}"
                        Label="Mijoz"
                        PrimaryTextMemberPath="Name"
                        SecondaryTextMemberPath="PhoneAndAddress"
                        SelectedItem="{Binding SelectedCustomer}"
                        ShowImage="False" />

                    <StackPanel Margin="15,0,0,0" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Text="Boshlanish:" />
                        <controls:UserCalendar
                            x:Name="dtBegin"
                            Width="130"
                            Height="32"
                            FontSize="14"
                            SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Margin="15,0,0,0" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Text="Tugash:" />
                        <controls:UserCalendar
                            x:Name="dtEnd"
                            Width="130"
                            Height="32"
                            FontSize="14"
                            SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                    </StackPanel>

                    <Button
                        x:Name="btnLoad"
                        Height="36"
                        Margin="15,0,0,0"
                        Padding="20,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding LoadCommand}"
                        Foreground="White"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Refresh" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Yuklash" />
                        </StackPanel>
                    </Button>

                    <Button
                        Height="36"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#78909C"
                        BorderThickness="0"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="White"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}"
                        ToolTip="Filterni tozalash">
                        <md:PackIcon Kind="FilterRemove" />
                    </Button>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnPreview"
                        Height="36"
                        Margin="5,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Eye" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Ko'rish" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="btnPrint"
                        Height="36"
                        Margin="5,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="Printer" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Pechat" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="btnExport"
                        Height="36"
                        Margin="5,0,0,0"
                        Padding="15,0"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#2E7D32"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon
                                Width="18"
                                Height="18"
                                VerticalAlignment="Center"
                                Kind="FileExcel" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Text="Excel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            BorderBrush="LightGray"
            BorderThickness="1"
            FontSize="14"
            IsReadOnly="True"
            ItemsSource="{Binding FilteredItems}"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="8,6" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="50" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                    Header="Sana">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Code}"
                    Header="Kodi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Nomi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="Padding" Value="5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Type}"
                    Header="Razmer">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding BundleCount}"
                    Header="Qop">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding BundleItemCount}"
                    Header="Dona">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding TotalCount, StringFormat=N0}"
                    Header="Jami">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding UnitPrice, StringFormat=N2}"
                    Header="Narxi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Amount, StringFormat=N2}"
                    Header="Summa">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding CurrencyCode}"
                    Header="Valyuta">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="2"
            Margin="0,10,0,0"
            Padding="15,10"
            Background="#E8F5E9"
            BorderBrush="#C8E6C9"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" FontSize="14">
                    <Run FontWeight="SemiBold" Text="Jami yozuvlar: " />
                    <Run Text="{Binding FilteredItems.Count, Mode=OneWay}" />
                    <Run Text=" ta" />
                </TextBlock>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#2E7D32">
                        <Run Text="Jami (so'm): " />
                        <Run Text="{Binding TotalSalesAmount, StringFormat={}{0:N2}, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="12"
                        Foreground="#6B7280"
                        Text="{Binding TotalsSummary, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
