<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.CustomerSalesRatingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  FILTER PANEL  -->
        <Border
            Grid.Row="0"
            Padding="1"
            Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  MIJOZ + SANA  -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="325" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Text="Hisobot davri" />
                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <controls:UserCalendar
                            x:Name="dateBegin"
                            Width="120"
                            Height="30"
                            SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                        <TextBlock
                            Margin="8,0"
                            VerticalAlignment="Center"
                            Text="dan" />
                        <controls:UserCalendar
                            x:Name="dateEnd"
                            Width="120"
                            Height="30"
                            SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                        <TextBlock
                            Margin="3,0"
                            VerticalAlignment="Center"
                            Text="gacha" />
                    </StackPanel>

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Text="Mijoz" />

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Height="30"
                            BorderBrush="#CCCCCC"
                            BorderThickness="2"
                            CornerRadius="4">
                            <ComboBox
                                x:Name="cbxCustomer"
                                Padding="3"
                                BorderThickness="0"
                                DisplayMemberPath="Name"
                                FontSize="14"
                                IsEditable="True"
                                ItemsSource="{Binding AvailableCustomers}"
                                SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}" />
                        </Border>

                        <Button
                            Grid.Column="1"
                            Width="80"
                            Height="30"
                            Margin="8,0,0,0"
                            md:ButtonAssist.CornerRadius="4"
                            Background="#673AB7"
                            BorderThickness="0"
                            Command="{Binding LoadSalesCommand}"
                            Content="Yuklash"
                            Foreground="White" />
                    </Grid>
                </Grid>

                <!--  TUGMALAR  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="20,0,15,0"
                    VerticalAlignment="Center">
                    <Button
                        x:Name="btnPreview"
                        Height="30"
                        Margin="0,5"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Content="Ko‘rish"
                        Foreground="White" />
                    <Button
                        x:Name="btnClear"
                        Height="30"
                        Margin="0,5"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#3949AB"
                        BorderThickness="0"
                        Command="{Binding ClearFilterCommand}"
                        Content="Tozalash"
                        Foreground="White" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="0"
                    VerticalAlignment="Center">
                    <Button
                        x:Name="btnPrint"
                        Height="30"
                        Margin="0,5"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Content="Pechat"
                        Foreground="White" />
                    <Button
                        x:Name="btnExport"
                        Height="30"
                        Margin="0,5"
                        md:ButtonAssist.CornerRadius="4"
                        Background="#2E7D32"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Content="Excel"
                        Foreground="White" />
                </StackPanel>

                <!--  QOLDIQLAR  -->
            </Grid>
        </Border>

        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F8F9FA"
            AutoGenerateColumns="False"
            BorderBrush="LightGray"
            BorderThickness="2"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding CustomerSales}"
            RowHeaderWidth="0"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <!--  🔹 Barcha headerlarni o‘rtaga tekislash  -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <!--  T/r  -->
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--  Mijoz nomi  -->
                <DataGridTextColumn Width="2*" Binding="{Binding CustomerName}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Mijoz nomi" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Tayyor  -->
                <DataGridTextColumn Width="*" Binding="{Binding ReadyCount, StringFormat=N0}">
                    <DataGridTextColumn.Header>
                        <TextBlock Foreground="#1565C0" Text="Tayyor" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#1565C0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Aralash  -->
                <DataGridTextColumn Width="*" Binding="{Binding MixedCount, StringFormat=N0}">
                    <DataGridTextColumn.Header>
                        <TextBlock Foreground="#6A1B9A" Text="Aralash" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#6A1B9A" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Eva  -->
                <DataGridTextColumn Width="*" Binding="{Binding EvaCount, StringFormat=N0}">
                    <DataGridTextColumn.Header>
                        <TextBlock Foreground="#D81B60" Text="Eva" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#D81B60" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--  Jami  -->
                <DataGridTextColumn Width="*" Binding="{Binding TotalCount, StringFormat=N0}">
                    <DataGridTextColumn.Header>
                        <TextBlock Foreground="#1B5E20" Text="Jami" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="ExtraBold" />
                            <Setter Property="Foreground" Value="#1B5E20" />
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="Background" Value="#E8F5E8" />
                            <Setter Property="Padding" Value="0,6" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>