<UserControl
    x:Class="Forex.Wpf.Pages.Reports.ViewModels.CustomerSalesRatingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:charts="clr-namespace:Forex.Wpf.Resources.Charts"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="White">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#7A8699" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Filter bar  -->
        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="#F8FAFD"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Boshlanish" />
                    <controls:UserCalendar
                        Width="120"
                        Height="34"
                        SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tugash" />
                    <controls:UserCalendar
                        Width="120"
                        Height="34"
                        SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Mijoz" />
                    <Border
                        Height="34"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        CornerRadius="6">
                        <ComboBox
                            Width="240"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            BorderThickness="0"
                            DisplayMemberPath="Name"
                            FontSize="14"
                            IsEditable="True"
                            ItemsSource="{Binding AvailableCustomers}"
                            SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#673AB7"
                        BorderThickness="0"
                        Command="{Binding LoadSalesCommand}"
                        Foreground="White"
                        ToolTip="Yuklash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Refresh" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Yuklash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                    <Button
                        Height="34"
                        Padding="14,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="White"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="#475467"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FilterRemoveOutline" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    Grid.Column="5"
                    Margin="0,0,12,0"
                    Padding="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="#EEF1F6"
                    CornerRadius="9">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="btnTableView"
                            Click="TableView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Jadval">
                            <md:PackIcon Width="18" Height="18" Kind="TableLarge" />
                        </Button>
                        <Button
                            x:Name="btnChartView"
                            Click="ChartView_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Diagramma">
                            <md:PackIcon Width="18" Height="18" Kind="ChartBar" />
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="6"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#1976D2"
                        BorderThickness="0"
                        Command="{Binding PreviewCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Ko'rish">
                        <md:PackIcon Width="18" Height="18" Kind="Eye" />
                    </Button>
                    <Button
                        Height="34"
                        Margin="5,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#00897B"
                        BorderThickness="0"
                        Command="{Binding PrintCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Pechat">
                        <md:PackIcon Width="18" Height="18" Kind="Printer" />
                    </Button>
                    <Button
                        Height="34"
                        Margin="5,0,0,0"
                        Padding="12,0"
                        md:ButtonAssist.CornerRadius="9"
                        Background="#15803D"
                        BorderThickness="0"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="White"
                        IsEnabled="{Binding HasData}"
                        ToolTip="Excel">
                        <md:PackIcon Width="18" Height="18" Kind="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  DataGrid  -->
        <DataGrid
            x:Name="grid"
            Grid.Row="1"
            Margin="0,14,0,0"
            AutoGenerateColumns="False"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ColumnHeaderHeight="42"
            EnableRowVirtualization="True"
            FontSize="14"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="#F0F2F6"
            IsReadOnly="True"
            ItemsSource="{Binding PagedItems}"
            RowHeight="40"
            VirtualizingStackPanel.VirtualizationMode="Standard">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F4F7FC" />
                    <Setter Property="Foreground" Value="#5A6477" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60" Header="T/r">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding RowNumber}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding CustomerName}"
                    Header="Mijoz nomi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding ReadyCount, StringFormat=N0}"
                    Header="Tayyor">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#1565C0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding MixedCount, StringFormat=N0}"
                    Header="Aralash">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#6A1B9A" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding EvaCount, StringFormat=N0}"
                    Header="Eva">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#D81B60" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding TotalCount, StringFormat=N0}"
                    Header="Jami">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="ExtraBold" />
                            <Setter Property="Foreground" Value="#1B5E20" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="1.4*"
                    Binding="{Binding TotalAmount, StringFormat=N0}"
                    Header="Jami summa">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,10,0" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Foreground" Value="#B7791F" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!--  Chart  -->
        <Border
            x:Name="chartPanel"
            Grid.Row="1"
            Margin="0,14,0,0"
            Padding="18,16"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <md:PackIcon
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Foreground="#673AB7"
                            Kind="Trophy" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#1F2937"
                            Text="Mijozlar reytingi" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Border
                            Padding="3"
                            Background="#EEF1F6"
                            CornerRadius="9">
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    x:Name="btnRateCount"
                                    Width="56"
                                    Click="RateCount_Click"
                                    Style="{StaticResource ViewToggleButton}"
                                    ToolTip="Soni bo'yicha">
                                    <TextBlock FontSize="12.5" Text="Soni" />
                                </Button>
                                <Button
                                    x:Name="btnRateSum"
                                    Width="64"
                                    Click="RateSum_Click"
                                    Style="{StaticResource ViewToggleButton}"
                                    ToolTip="Summa bo'yicha">
                                    <TextBlock FontSize="12.5" Text="Summa" />
                                </Button>
                            </StackPanel>
                        </Border>
                        <Button
                            x:Name="btnRateSort"
                            Margin="10,0,0,0"
                            Click="RateSort_Click"
                            Style="{StaticResource ViewToggleButton}"
                            ToolTip="Tartib (o'sish / kamayish)">
                            <md:PackIcon
                                x:Name="icoRateSort"
                                Width="18"
                                Height="18"
                                Kind="SortDescending" />
                        </Button>
                    </StackPanel>
                </Grid>
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <charts:BarChart
                        VerticalAlignment="Top"
                        Accent="#673AB7"
                        MaxValue="{Binding ChartMax}"
                        Points="{Binding RatingChart}"
                        RowHeight="34" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  Totals + Pager  -->
        <Border
            Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12,10"
            Background="White"
            BorderBrush="#EAEEF5"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Rows="1">
                    <controls:StatCard
                        Accent="#3949AB"
                        CardBackground="#EEF2FF"
                        Title="Mijozlar"
                        TitleBrush="#6470B0"
                        Value="{Binding TotalCount}" />
                    <controls:StatCard
                        Accent="#1B7A3E"
                        CardBackground="#E9F8EE"
                        Title="Jami juft"
                        TitleBrush="#2E8B57"
                        Value="{Binding SummaryPairs, StringFormat=N0}" />
                    <controls:StatCard
                        Accent="#A66A12"
                        Caption="{Binding AmountBreakdown}"
                        CardBackground="#FFF6E6"
                        Title="Jami summa (so'm)"
                        TitleBrush="#B7791F"
                        Value="{Binding SummaryAmount, StringFormat=N0}" />
                </UniformGrid>

                <controls:Pager
                    Grid.Column="1"
                    CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                    TotalPages="{Binding TotalPages}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
