<Page
    x:Class="Forex.Wpf.Pages.Home.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:charts="clr-namespace:Forex.Wpf.Resources.Charts"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Forex.Wpf.Pages.Home"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:svc="clr-namespace:Forex.Wpf.Common.Services"
    Title="HomePage"
    d:DesignHeight="580"
    d:DesignWidth="810"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource PrimaryBackground}" TextElement.Foreground="{DynamicResource InkPrimary}">
        <!--  Main Content  -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="mainContent">
            <!--  Modern Navbar  -->
            <Border
                x:Name="mainMenu"
                Height="65"
                Margin="10"
                Padding="15,0"
                md:ElevationAssist.Elevation="Dp8"
                Background="{DynamicResource Accent}"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  LOGO  -->
                    <Border
                        Width="120"
                        Height="45"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        md:ElevationAssist.Elevation="Dp3"
                        CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="/Resources/Assets/logo.png" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>

                    <!--  Right Side: Notifications + User Profile  -->
                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <!--  Notification Button  -->
                        <Button
                            x:Name="btnNotifications"
                            Width="40"
                            Height="40"
                            Margin="0,0,12,0"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnNotifications_Click"
                            Visibility="{Binding CanReports, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTip="Bildirishnomalar">
                            <Grid>
                                <md:PackIcon
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource OnAccent}"
                                    Kind="Bell" />
                                <!--  Badge for notification count  -->
                                <Border
                                    x:Name="notificationBadge"
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource Danger}"
                                    CornerRadius="9"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        x:Name="notificationCount"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource OnAccent}"
                                        Text="3" />
                                </Border>
                            </Grid>
                        </Button>

                        <!--  User Profile Section  -->
                        <Button
                            x:Name="btnUserProfile"
                            Height="45"
                            Padding="8,0"
                            md:ButtonAssist.CornerRadius="10"
                            Background="#3FFFFFFF"
                            BorderThickness="0"
                            Click="BtnUserProfile_Click"
                            Cursor="Hand">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <!--  User Avatar  -->
                                <Ellipse
                                    Width="35"
                                    Height="35"
                                    Stroke="{DynamicResource OnAccent}"
                                    StrokeThickness="2">
                                    <Ellipse.Fill>
                                        <ImageBrush
                                            x:Name="imgUserAvatar"
                                            ImageSource="/Resources/Assets/profile.jpg"
                                            Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                </Ellipse>

                                <!--  User Name  -->
                                <TextBlock
                                    Margin="10,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource OnAccent}"
                                    Text="{Binding FullName}" />

                                <!--  Dropdown Icon  -->
                                <md:PackIcon
                                    x:Name="dropdownIcon"
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource OnAccent}"
                                    Kind="ChevronDown">
                                    <md:PackIcon.RenderTransform>
                                        <RotateTransform x:Name="dropdownRotation" Angle="0" CenterX="10" CenterY="10" />
                                    </md:PackIcon.RenderTransform>
                                </md:PackIcon>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  User Profile Dropdown Popup  -->
            <Popup
                x:Name="userProfilePopup"
                AllowsTransparency="True"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=btnUserProfile}"
                PopupAnimation="Fade"
                StaysOpen="False">
                <Border
                    MinWidth="220"
                    Margin="10"
                    md:ElevationAssist.Elevation="Dp16"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource HairlineBorder}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Margin="0,8">
                        <!--  User Info Header  -->
                        <StackPanel Margin="16,8,16,12" Orientation="Horizontal">
                            <Border
                                Width="45"
                                Height="45"
                                BorderBrush="{DynamicResource Accent}"
                                BorderThickness="2"
                                CornerRadius="22.5">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ElementName=imgUserAvatar, Path=ImageSource}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource InkPrimary}"
                                    Text="{Binding FullName}" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource InkMuted}"
                                    Text="{Binding Username}" />
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="8,0" Background="{DynamicResource HairlineBorder}" />

                        <!--  Menu Items  -->
                        <Button
                            x:Name="btnEditProfile"
                            Height="40"
                            Padding="16,0"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnEditProfile_Click"
                            Cursor="Hand">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource Accent}"
                                    Kind="AccountEdit" />
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{DynamicResource InkPrimary}"
                                    Text="Profilni tahrirlash" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="btnAccountSettings"
                            Height="40"
                            Padding="16,0"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnAccountSettings_Click"
                            Cursor="Hand">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource InkMuted}"
                                    Kind="Settings" />
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{DynamicResource InkPrimary}"
                                    Text="Sozlamalar" />
                            </StackPanel>
                        </Button>

                        <Separator Margin="8,4" Background="{DynamicResource HairlineBorder}" />

                        <Button
                            x:Name="btnLogoutMenu"
                            Height="40"
                            Padding="16,0"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnLogout_Click"
                            Cursor="Hand">
                            <Button.Style>
                                <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource DangerSoft}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource Danger}"
                                    Kind="Logout" />
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{DynamicResource Danger}"
                                    Text="Chiqish" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <!--  Overdue Warning (kept from original)  -->
            <Popup
                x:Name="overdueWarningPopup"
                AllowsTransparency="True"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=btnNotifications}"
                StaysOpen="False"
                Visibility="Collapsed">
                <Border
                    Padding="12"
                    md:ElevationAssist.Elevation="Dp8"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource HairlineBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <TextBlock Foreground="{DynamicResource Danger}" Text="Qarz to'lash muddati o'tgan mijozlar bor!" />
                </Border>
            </Popup>


            <WrapPanel Margin="35,20">
                <Button
                    x:Name="btnSale"
                    Visibility="{Binding CanSales, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource Teal}"
                    Click="BtnSale_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    🛒 Savdo
                </Button>

                <Button
                    x:Name="btnReturn"
                    Visibility="{Binding CanReturns, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource Warning}"
                    Click="BtnReturn_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    ↩️ Qaytarish
                </Button>

                <Button
                    x:Name="btnCash"
                    Visibility="{Binding CanPayments, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource IconBlue}"
                    Click="BtnCash_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
					💰 To'lov
                </Button>

                <Button
                    x:Name="btnProduct"
                    Visibility="{Binding CanProducts, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource Success}"
                    Click="BtnProduct_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    👟 Mahsulot
                </Button>

                <Button
                    x:Name="btnBarcode"
                    Visibility="{Binding CanBarcode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource IconPink}"
                    Click="BtnBarcode_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    🏷 Barkod
                </Button>

                <Button
                    x:Name="btnSupply"
                    Visibility="{Binding CanSupply, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource IconViolet}"
                    Click="BtnSupply_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    📦 Ta'minot
                </Button>

                <Button
                    x:Name="btnUser"
                    Visibility="{Binding CanUsers, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource Accent}"
                    Click="BtnUser_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    👤 User
                </Button>

                <Button
                    x:Name="btnReports"
                    Visibility="{Binding CanReports, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource IconOrange}"
                    Click="btnReports_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    📈 Hisobot
                </Button>

                <Button
                    x:Name="btnSettings"
                    Visibility="{Binding CanSettings, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="120"
                    MinWidth="220"
                    Margin="10"
                    md:ButtonAssist.CornerRadius="10"
                    md:ElevationAssist.Elevation="Dp24"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="{DynamicResource Danger}"
                    Click="BtnSettings_Click"
                    FontSize="24"
                    FontWeight="Medium"
                    Foreground="{DynamicResource MainMenuTextColor}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}">
                    ⚙️ Sozlama
                </Button>


            </WrapPanel>

            <!--  Dashboard  -->
            <StackPanel x:Name="dashboardRoot" Margin="35,0,35,30">
                <Grid
                    Margin="0,0,0,14"
                    Visibility="{Binding AnyDashboardVisible, Source={x:Static svc:AppPreferences.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <md:PackIcon Width="22" Height="22" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" Kind="ViewDashboardOutline" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource InkPrimary}" Text="Boshqaruv paneli" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource InkFaint}" Text="{Binding PeriodLabel}" />
                    </StackPanel>

                    <Border
                        Padding="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SurfaceChip}"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="chipDay" Width="58" Click="Chip_Click" Style="{StaticResource ViewToggleButton}" Tag="Day">
                                <TextBlock FontSize="12.5" Text="Kun" />
                            </Button>
                            <Button x:Name="chipWeek" Width="64" Click="Chip_Click" Style="{StaticResource ViewToggleButton}" Tag="Week">
                                <TextBlock FontSize="12.5" Text="Xafta" />
                            </Button>
                            <Button x:Name="chipMonth" Width="58" Click="Chip_Click" Style="{StaticResource ViewToggleButton}" Tag="Month">
                                <TextBlock FontSize="12.5" Text="Oy" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <UniformGrid
                    Margin="0,0,0,14"
                    Rows="1"
                    Visibility="{Binding ShowDashboardStats, Source={x:Static svc:AppPreferences.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:StatCard Accent="{DynamicResource Success}" CardBackground="{DynamicResource SuccessSoft}" Title="Savdo (so'm)" TitleBrush="{DynamicResource Success}" Value="{Binding RangeSales, StringFormat=N0}" />
                    <controls:StatCard Accent="{DynamicResource Accent}" CardBackground="{DynamicResource AccentSoft}" Title="Savdolar" TitleBrush="{DynamicResource InkSecondary}" Value="{Binding RangeCount}" />
                    <controls:StatCard Accent="{DynamicResource Warning}" CardBackground="{DynamicResource WarningSoft}" Title="Sotilgan juft" TitleBrush="{DynamicResource Warning}" Value="{Binding RangePairs, StringFormat=N0}" />
                    <controls:StatCard Accent="{DynamicResource IconPink}" CardBackground="{DynamicResource IconPinkSoft}" Title="O'rtacha savdo (so'm)" TitleBrush="{DynamicResource IconPink}" Value="{Binding AvgSale, StringFormat=N0}" />
                </UniformGrid>

                <Border
                    Height="260"
                    Margin="0,0,0,14"
                    Padding="16"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource HairlineBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Visibility="{Binding ShowSalesTrend, Source={x:Static svc:AppPreferences.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" Kind="ChartLine" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource InkPrimary}" Text="Savdo va to'lovlar dinamikasi (so'm)" />
                        </StackPanel>
                        <charts:LineChart Grid.Row="1" Margin="0,10,0,0" Data="{Binding SalesTrend}" />
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Height="250"
                        Padding="16"
                        Background="{DynamicResource SurfaceCard}"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding ShowTopCustomers, Source={x:Static svc:AppPreferences.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource IconViolet}" Kind="AccountStar" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource InkPrimary}" Text="Top mijozlar (so'm)" />
                            </StackPanel>
                            <charts:BarChart Grid.Row="1" Margin="0,10,0,0" Accent="{DynamicResource IconVioletColorValue}" Points="{Binding TopCustomers}" />
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Height="250"
                        Padding="16"
                        Background="{DynamicResource SurfaceCard}"
                        BorderBrush="{DynamicResource HairlineBorder}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding ShowTopProducts, Source={x:Static svc:AppPreferences.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource Success}" Kind="ShoeSneaker" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource InkPrimary}" Text="Top mahsulotlar (juft)" />
                            </StackPanel>
                            <charts:BarChart Grid.Row="1" Margin="0,10,0,0" Accent="{DynamicResource SuccessColorValue}" Points="{Binding TopProducts}" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!--  Profile Edit Modal Overlay  -->
        <Grid
            x:Name="profileEditOverlay"
            Background="{DynamicResource Scrim}"
            Visibility="Collapsed">
            <Border
                Width="580"
                Height="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                md:ElevationAssist.Elevation="Dp24"
                Background="{DynamicResource PrimaryBackground}"
                CornerRadius="16">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource SecondaryTextColor}"
                            Text="👤 Profil sozlamalari" />
                    </StackPanel>

                    <!--  Content  -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!--  Avatar Section with Hover Effect  -->
                            <Border
                                Margin="0,0,0,25"
                                Padding="20"
                                HorizontalAlignment="Center"
                                md:ElevationAssist.Elevation="Dp4"
                                Background="{DynamicResource SurfaceCard}"
                                CornerRadius="15">
                                <Grid
                                    x:Name="avatarContainer"
                                    Width="120"
                                    Height="120">
                                    <Ellipse
                                        Width="120"
                                        Height="120"
                                        md:ElevationAssist.Elevation="Dp8"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="Avatar_Click"
                                        Stroke="{DynamicResource Accent}"
                                        StrokeThickness="3">
                                        <Ellipse.Fill>
                                            <ImageBrush
                                                x:Name="imgProfilePreview"
                                                ImageSource="/Resources/Assets/profile.jpg"
                                                Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!--  Hover Overlay with Gradient  -->
                                    <Grid
                                        x:Name="avatarOverlay"
                                        Background="Transparent"
                                        IsHitTestVisible="False">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <!--  Gradient overlay - dark at bottom, transparent at top  -->
                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0.3" EndPoint="0.5,1">
                                                    <GradientStop Offset="0" Color="#00000000" />
                                                    <GradientStop Offset="1.0" Color="Black" />
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!--  Icon and text positioned at bottom half  -->
                                        <StackPanel
                                            Margin="0,0,0,25"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom">
                                            <md:PackIcon
                                                Width="30"
                                                Height="30"
                                                HorizontalAlignment="Center"
                                                Foreground="White"
                                                Kind="Camera" />
                                            <TextBlock
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="Rasm yuklash" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!--  Profile Fields  -->
                            <Border
                                Padding="20"
                                md:ElevationAssist.Elevation="Dp4"
                                Background="{DynamicResource SurfaceCard}"
                                CornerRadius="12">
                                <StackPanel>
                                    <!--  Full Name  -->
                                    <controls:FloatingInput
                                        x:Name="tbxFullName"
                                        Margin="0,10,0,25"
                                        Label="Ism va Familiya"
                                        Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!--  Username (Read-only)  -->
                                    <controls:FloatingInput
                                        x:Name="tbxUsername"
                                        Margin="0,0,0,25"
                                        IsReadOnly="True"
                                        Label="Login (o'zgartirib bo'lmaydi)"
                                        Text="{Binding Username, Mode=OneWay}" />

                                    <!--  Phone  -->
                                    <controls:FloatingInput
                                        x:Name="tbxPhone"
                                        Margin="0,0,0,25"
                                        Label="Telefon"
                                        Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!--  Email  -->
                                    <controls:FloatingInput
                                        x:Name="tbxEmail"
                                        Margin="0,0,0,25"
                                        Label="Email"
                                        Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!--  Address  -->
                                    <controls:FloatingInput
                                        x:Name="tbxAddress"
                                        Label="Manzil"
                                        Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <Separator Margin="0,10,0,15" Background="{DynamicResource HairlineBorder}" />

                                    <!--  Password Section  -->
                                    <TextBlock
                                        Margin="0,0,0,10"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource InkMuted}"
                                        Text="Parolni o'zgartirish" />

                                    <PasswordBox
                                        x:Name="pwdNewPassword"
                                        Margin="0,0,0,10"
                                        Padding="10"
                                        md:HintAssist.Foreground="{DynamicResource InkMuted}"
                                        md:HintAssist.Hint="Yangi parol (ixtiyoriy)"
                                        md:TextFieldAssist.HasClearButton="True"
                                        BorderBrush="{DynamicResource HairlineBorder}"
                                        Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />

                                    <PasswordBox
                                        x:Name="pwdConfirmPassword"
                                        Margin="0,0,0,5"
                                        Padding="10"
                                        md:HintAssist.Foreground="{DynamicResource InkMuted}"
                                        md:HintAssist.Hint="Parolni tasdiqlash"
                                        md:TextFieldAssist.HasClearButton="True"
                                        BorderBrush="{DynamicResource HairlineBorder}"
                                        Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!--  Action Buttons  -->
                    <StackPanel
                        Grid.Row="2"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            x:Name="btnSaveProfile"
                            Width="140"
                            Margin="0,0,10,0"
                            Padding="12,0"
                            md:ButtonAssist.CornerRadius="8"
                            Background="{DynamicResource SuccessStrong}"
                            Click="BtnSaveProfile_Click"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource OnAccent}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Kind="ContentSave" />
                                <TextBlock Margin="8,0,0,0" Text="Saqlash" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="btnCloseModal"
                            Width="140"
                            Padding="12,0"
                            md:ButtonAssist.CornerRadius="8"
                            Background="{DynamicResource SecondaryButtonBackground}"
                            Click="BtnCloseModal_Click"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource SecondaryButtonForeground}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Kind="Close" />
                                <TextBlock Margin="8,0,0,0" Text="Bekor qilish" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
