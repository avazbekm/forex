<Page
    x:Class="Forex.Wpf.Pages.Supply.Views.SupplyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Ta'minot"
    d:DesignHeight="640"
    d:DesignWidth="940"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#666666" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryBackground}">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource SecondaryTextColor}"
                    Text="Ta'minot" />

                <Button
                    x:Name="btnBack"
                    HorizontalAlignment="Right"
                    md:ButtonAssist.CornerRadius="5"
                    Background="{DynamicResource OtherBackground}"
                    BorderThickness="0"
                    Click="BtnBack_Click"
                    Content="Orqaga" />
            </Grid>

            <Border
                Grid.Row="1"
                Margin="0,12,0,12"
                Padding="14"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,10,10">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Sana" />
                        <controls:UserCalendar
                            Width="135"
                            Height="34"
                            SelectedDate="{Binding Date, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,10">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Hisob turi" />
                        <ComboBox
                            Height="34"
                            DisplayMemberPath="Text"
                            ItemsSource="{Binding PartyTypes}"
                            SelectedItem="{Binding SelectedPartyTypeOption, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,10">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Ta'minotchi / Vositachi" />
                        <ComboBox
                            Height="34"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding AvailableUsers}"
                            SelectedItem="{Binding SelectedUser, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,10,10">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Valyuta" />
                        <ComboBox
                            Height="34"
                            DisplayMemberPath="Code"
                            ItemsSource="{Binding AvailableCurrencies}"
                            SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,10,10">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Summa" />
                        <TextBox
                            PreviewTextInput="NumericTextBox_PreviewTextInput"
                            Style="{StaticResource InputTextBoxStyle}"
                            Text="{Binding Amount, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Izoh" />
                        <TextBox
                            Height="34"
                            Style="{StaticResource InputTextBoxStyle}"
                            Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button
                        Grid.Row="2"
                        Grid.Column="3"
                        Width="120"
                        VerticalAlignment="Bottom"
                        Height="36"
                        md:ElevationAssist.Elevation="Dp8"
                        Background="{StaticResource SuccessButtonBackground}"
                        BorderBrush="{StaticResource SuccessButtonBorder}"
                        Command="{Binding SubmitCommand}"
                        Content="{Binding SubmitButtonText}"
                        Foreground="{StaticResource SuccessButtonForeground}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}" />
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="10,10,10,0"
                        Padding="10"
                        Background="#FAFAFA"
                        BorderBrush="#E7E7E7"
                        BorderThickness="1"
                        CornerRadius="4">
                        <DockPanel >
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Boshlanish sanasi" />
                                <controls:UserCalendar
                                    Width="135"
                                    Height="34"
                                    SelectedDate="{Binding FilterBeginDate, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tugash sanasi" />
                                <controls:UserCalendar
                                    Width="135"
                                    Height="34"
                                    SelectedDate="{Binding FilterEndDate, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Shaxs" />
                                <ComboBox
                                    Width="180"
                                    Height="34"
                                    DisplayMemberPath="Text"
                                    ItemsSource="{Binding AvailableFilterUsers}"
                                    SelectedItem="{Binding SelectedFilterUser, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Turi" />
                                <ComboBox
                                    Width="150"
                                    Height="34"
                                    DisplayMemberPath="Text"
                                    ItemsSource="{Binding SupplyFilterOptions}"
                                    SelectedItem="{Binding SelectedSupplyFilterOption, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Valyuta" />
                                <ComboBox
                                    Width="120"
                                    Height="34"
                                    DisplayMemberPath="Text"
                                    ItemsSource="{Binding CurrencyFilterOptions}"
                                    SelectedItem="{Binding SelectedCurrencyFilter, Mode=TwoWay}" />
                            </StackPanel>

                            <Button
                                Width="110"
                                Height="34"
                                Margin="0,17,0,0"
                                Background="#2E7D32"
                                HorizontalAlignment="Right"
                                BorderThickness="0"
                                Command="{Binding ExportToExcelCommand}"
                                Foreground="White">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="FileExcel" />
                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Excel" />
                                </StackPanel>
                            </Button>
                        </DockPanel>
                    </Border>

                    <DataGrid
                        Grid.Row="1"
                        Margin="10"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding Supplies}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                Header="Sana" />
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding PartyTypeText}"
                                Header="Turi" />
                            <DataGridTextColumn
                                Width="170"
                                Binding="{Binding User.Name}"
                                Header="Kimdan" />
                            <DataGridTextColumn
                                Width="130"
                                Binding="{Binding Amount, StringFormat={}{0:N0}}"
                                Header="Summa" />
                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding Currency.Code}"
                                Header="Valyuta" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Description}"
                                Header="Izoh" />
                            <DataGridTemplateColumn Width="92" Header="">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <Button
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Tahrirlash">
                                                <md:PackIcon Width="16" Height="16" Kind="Pencil" />
                                            </Button>
                                            <Button
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="O'chirish">
                                                <md:PackIcon Width="16" Height="16" Kind="Delete" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border
                        Grid.Row="2"
                        Margin="10,0,10,10"
                        Padding="12,8"
                        Background="#F3F8F4"
                        BorderBrush="#D8EAD9"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="Yozuvlar: " />
                                <TextBlock FontWeight="Bold" Text="{Binding FilteredCount}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="Ta'minotchi: " />
                                <TextBlock FontWeight="Bold" Text="{Binding FilteredSupplierAmount, StringFormat={}{0:N0}}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="Vositachi: " />
                                <TextBlock FontWeight="Bold" Text="{Binding FilteredConsolidatorAmount, StringFormat={}{0:N0}}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Jami: " />
                                <TextBlock FontSize="15" FontWeight="Bold" Text="{Binding FilteredTotalAmount, StringFormat={}{0:N0}}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
