<Page
    x:Class="Forex.Wpf.Pages.Transactions.Views.TransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="O'tkazmalar"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="6,0" />
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource SurfacePage}" TextElement.Foreground="{DynamicResource InkPrimary}">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Grid Grid.Row="0" Margin="2,0,2,4">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="42"
                        Height="42"
                        Background="{DynamicResource AccentSoft}"
                        CornerRadius="11">
                        <md:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource Accent}"
                            Kind="CashMultiple" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{DynamicResource InkPrimary}"
                            Text="To'lovlar" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource InkFaint}"
                            Text="Mijoz va hamkorlar bilan hisob-kitob" />
                    </StackPanel>
                </StackPanel>

                <Button
                    x:Name="btnBack"
                    Height="38"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource HairlineBorder}"
                    BorderThickness="1"
                    Click="BtnBack_Click"
                    Foreground="{DynamicResource InkSecondary}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Kind="ArrowLeft" />
                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Orqaga" />
                    </StackPanel>
                </Button>
            </Grid>

            <!--  Entry form (placement preserved)  -->
            <Border
                Grid.Row="1"
                Margin="0,14,0,14"
                Padding="18"
                Background="{DynamicResource SurfaceCard}"
                CornerRadius="14"
                md:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="500" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Left Section: Transaction Details  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Row 0: Date and User  -->
                        <Label
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="Sana:"
                            FontSize="14" />
                        <controls:UserCalendar
                            x:Name="dateControl"
                            Grid.Column="1"
                            Height="30"
                            Margin="0,1,0,1"
                            FontSize="14"
                            SelectedDate="{Binding Transaction.Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Label
                            Grid.Column="2"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="User:"
                            FontSize="14" />
                        <controls:FloatingImageComboBox
                            x:Name="cbUser"
                            Grid.Column="3"
                            Height="32"
                            Margin="0,2"
                            IsEditable="True"
                            IsSearchEnabled="True"
                            IsTextSearchEnabled="False"
                            ItemsSource="{Binding FilteredUsers}"
                            PrimaryTextMemberPath="Name"
                            SecondaryTextMemberPath="PhoneAndAddress"
                            SelectedItem="{Binding Transaction.User}"
                            ShowImage="False"
                            Text="{Binding UserFilterText, Mode=TwoWay}" />

                        <!--  Row 1: Currency and Income  -->
                        <Label
                            Grid.Row="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="Val. turi:"
                            FontSize="14" />
                        <Border
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,2,10,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ComboBox
                                x:Name="cbCurrency"
                                Padding="5,1"
                                Background="Transparent"
                                BorderThickness="0"
                                Style="{StaticResource MaterialDesignComboBox}"
                                md:TextFieldAssist.DecorationVisibility="Collapsed"
                                DisplayMemberPath="Name"
                                FontSize="14"
                                ItemsSource="{Binding AvailableCurrencies}"
                                SelectedItem="{Binding Transaction.Currency}" />
                        </Border>

                        <Label
                            Grid.Row="1"
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="Kirim:"
                            FontSize="14" />
                        <Border
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="0,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4"
                            IsEnabled="{Binding IsIncomeEnabled}">
                            <TextBox
                                x:Name="tbKirim"
                                Padding="3,0"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                BorderThickness="0"
                                FontSize="14"
                                PreviewTextInput="NumericTextBox_PreviewTextInput"
                                Text="{Binding Transaction.Income, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                TextAlignment="Right" />
                        </Border>

                        <!--  Row 2: Payment Method and Expense  -->
                        <Label
                            Grid.Row="2"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="To'lov turi:"
                            FontSize="14" />
                        <Border
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,2,10,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ComboBox
                                x:Name="cbPaymentMethod"
                                Padding="5,1"
                                Background="Transparent"
                                BorderThickness="0"
                                Style="{StaticResource MaterialDesignComboBox}"
                                md:TextFieldAssist.DecorationVisibility="Collapsed"
                                FontSize="14"
                                ItemsSource="{Binding AvailablePaymentMethods}"
                                SelectedItem="{Binding Transaction.PaymentMethod}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>

                        <Label
                            Grid.Row="2"
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="Chiqim:"
                            FontSize="14" />
                        <Border
                            Grid.Row="2"
                            Grid.Column="3"
                            Margin="0,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4"
                            IsEnabled="{Binding IsExpenseEnabled}">
                            <TextBox
                                x:Name="tbChiqim"
                                Padding="3,0"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                BorderThickness="0"
                                FontSize="14"
                                PreviewTextInput="NumericTextBox_PreviewTextInput"
                                Text="{Binding Transaction.Expense, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                TextAlignment="Right" />
                        </Border>

                        <!--  Row 3: Exchange Rate and Discount  -->
                        <Label
                            Grid.Row="3"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="Kurs:"
                            FontSize="14" />
                        <Border
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="0,2,10,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBox
                                x:Name="tbExchangeRate"
                                Padding="3,0"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                BorderThickness="0"
                                FontSize="14"
                                IsEnabled="{Binding IsExchangeRateEnabled}"
                                Text="{Binding Transaction.ExchangeRate, StringFormat={}{0:0.######}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                TextAlignment="Right" />
                        </Border>

                        <Label
                            Grid.Row="3"
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="Chegirma:"
                            FontSize="14" />
                        <Border
                            Grid.Row="3"
                            Grid.Column="3"
                            Margin="0,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBox
                                x:Name="tbDiscount"
                                Padding="3,0"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                BorderThickness="0"
                                FontSize="14"
                                IsEnabled="{Binding IsDiscountEnabled}"
                                PreviewTextInput="NumericTextBox_PreviewTextInput"
                                Text="{Binding Transaction.Discount, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                TextAlignment="Right" />
                        </Border>

                        <!--  Row 4: Description  -->
                        <Label
                            Grid.Row="4"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="Izoh:"
                            FontSize="14" />
                        <Border
                            Grid.Row="4"
                            Grid.Column="1"
                            Grid.ColumnSpan="3"
                            Margin="0,2"
                            BorderBrush="{DynamicResource PrimaryTextColor}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBox
                                x:Name="tbDescription"
                                Padding="3,0"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                BorderThickness="0"
                                FontSize="14"
                                Text="{Binding Transaction.Description}" />
                        </Border>
                    </Grid>

                    <!--  Right Section: Account Summary  -->
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontStyle="Italic"
                            FontWeight="Bold"
                            Text="{Binding Transaction.User.CurrencyCode, StringFormat='Hisob ({0}):', FallbackValue='Hisob:', TargetNullValue='Hisob:'}" />

                        <TextBlock
                            Grid.Row="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="Joriy:" />
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            IsReadOnly="True"
                            IsTabStop="False"
                            Text="{Binding TotalAmountWithUserBalance, StringFormat={}{0:N2}, TargetNullValue=''}" />

                        <TextBlock
                            Grid.Row="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="Qoldiq:" />
                        <TextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            IsReadOnly="True"
                            Text="{Binding Transaction.User.Balance, StringFormat={}{0:N2}, TargetNullValue=''}" />

                        <TextBlock
                            Grid.Row="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="Telefon:" />
                        <TextBox
                            Grid.Row="3"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            IsReadOnly="True"
                            IsTabStop="False"
                            Text="{Binding Transaction.User.Phone}" />

                        <TextBlock
                            Grid.Row="4"
                            Grid.RowSpan="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="To'lash sana:"
                            Visibility="{Binding Transaction.IsDebtor, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <controls:UserCalendar
                            Grid.Row="4"
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Height="25"
                            Margin="10,0"
                            FontSize="14"
                            SelectedDate="{Binding Transaction.DueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding Transaction.IsDebtor, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!--  To'lash/Yangilash tugmasi  -->
                        <Button
                            x:Name="btnSubmit"
                            Grid.Row="4"
                            Grid.Column="2"
                            Height="28"
                            Margin="10,0,0,0"
                            Padding="0"
                            md:ElevationAssist.Elevation="Dp8"
                            Background="{StaticResource SuccessButtonBackground}"
                            BorderBrush="{StaticResource SuccessButtonBorder}"
                            Command="{Binding SubmitCommand}"
                            Content="{Binding IsEditing, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Saqlash | To‘lash '}"
                            Foreground="{StaticResource SuccessButtonForeground}" />

                        <!--  Bekor qilish tugmasi (faqat edit rejimida)  -->
                        <Button
                            x:Name="btnCancel"
                            Grid.Row="4"
                            Grid.Column="3"
                            Height="28"
                            Margin="10,0,0,0"
                            Padding="0"
                            md:ElevationAssist.Elevation="Dp8"
                            Background="{DynamicResource Danger}"
                            BorderBrush="{DynamicResource Danger}"
                            Command="{Binding CancelCommand}"
                            Content="Bekor qilish"
                            Foreground="{StaticResource SuccessButtonForeground}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>

            <!--  History Filter  -->
            <Border
                Grid.Row="2"
                Margin="0,0,0,10"
                Padding="14,12"
                Background="{DynamicResource SurfaceMuted}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0">
                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Boshlanish" />
                            <controls:UserCalendar
                                Width="120"
                                Height="30"
                                FontSize="14"
                                SelectedDate="{Binding BeginDate, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tugash" />
                            <controls:UserCalendar
                                Width="120"
                                Height="30"
                                FontSize="14"
                                SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Hisob turi" />
                            <controls:FloatingComboBox
                                Width="130"
                                DisplayMemberPath="Text"
                                ItemsSource="{Binding UserRoleFilterOptions}"
                                SelectedItem="{Binding SelectedUserRoleFilter}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Shaxs" />
                            <controls:FloatingComboBox
                                Width="200"
                                DisplayMemberPath="Text"
                                ItemsSource="{Binding FilterPanelUserOptions}"
                                SelectedItem="{Binding SelectedFilterUser}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Turi" />
                            <controls:FloatingComboBox
                                Width="120"
                                DisplayMemberPath="Text"
                                ItemsSource="{Binding TransactionTypeOptions}"
                                SelectedItem="{Binding SelectedTransactionTypeOption}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="To'lov usuli" />
                            <controls:FloatingComboBox
                                Width="130"
                                DisplayMemberPath="Text"
                                ItemsSource="{Binding AvailablePaymentMethodFilters}"
                                SelectedItem="{Binding SelectedPaymentMethodFilter}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                            <Button
                                Height="30"
                                Padding="14,0"
                                md:ButtonAssist.CornerRadius="9"
                                Background="{DynamicResource SurfaceCard}"
                                BorderBrush="{DynamicResource HairlineBorder}"
                                BorderThickness="1"
                                Command="{Binding ClearFiltersCommand}"
                                Foreground="{DynamicResource InkSecondary}"
                                ToolTip="Filterlarni tozalash">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon
                                        Width="16"
                                        Height="16"
                                        VerticalAlignment="Center"
                                        Kind="FilterRemoveOutline" />
                                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                        <Button
                            Height="30"
                            Padding="14,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="{DynamicResource SuccessStrong}"
                            BorderThickness="0"
                            Command="{Binding ExportToExcelCommand}"
                            Foreground="{DynamicResource OnAccent}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Kind="FileExcel" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Excel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Transaction History DataGrid  -->
            <DataGrid
                Grid.Row="3"
                AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                AutoGenerateColumns="False"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CanUserAddRows="False"
                VirtualizingStackPanel.VirtualizationMode="Standard"
                EnableRowVirtualization="True"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding Transactions}"
                RowHeight="40"
                ColumnHeaderHeight="40"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
                SelectionMode="Single">

                <DataGrid.Resources>
                    <Style x:Key="RightAlignedCellStyle" TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Right" />
                        <Setter Property="Padding" Value="0,0,5,0" />
                    </Style>

                    <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
                        <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="60" Header="T/r">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IndexConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="Sana" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding User.Name}"
                        Header="User" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding PaymentMethod}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="To'lov turi" />
                    <DataGridTextColumn
                        Width="0.5*"
                        Binding="{Binding Currency.Name}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="Valyuta turi" />
                    <DataGridTextColumn
                        Width="0.5*"
                        Binding="{Binding ExchangeRate, StringFormat={}{0:N2}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Kurs" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Income, StringFormat={}{0:N2}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Kirim" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Expense, StringFormat={}{0:N2}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Chiqim" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Description}"
                        Header="Izoh" />

                    <DataGridTemplateColumn Width="90" Header="Amallar">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="4" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <!--  EDIT BUTTON  -->
                                                <Button
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource EditActionButton}"
                                                    ToolTip="Tahrirlash">
                                                    <md:PackIcon
                                                        Width="16"
                                                        Height="16"
                                                        Kind="Pencil" />
                                                </Button>
                                                <!--  DELETE BUTTON  -->
                                                <Button
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DeleteActionButton}"
                                                    ToolTip="O'chirish">
                                                    <md:PackIcon
                                                        Width="16"
                                                        Height="16"
                                                        Kind="Delete" />
                                                </Button>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!--  Totals — horizontal stat cards  -->
            <Grid Grid.Row="4" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{DynamicResource SuccessSoft}"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="Medium"
                            Foreground="{DynamicResource Success}"
                            Text="Jami kirim" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Success}">
                            <Run Text="{Binding TotalIncome, StringFormat={}{0:N2}}" />
                            <Run Text=" so'm" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{DynamicResource DangerSoft}"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="Medium"
                            Foreground="{DynamicResource Danger}"
                            Text="Jami chiqim" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Danger}">
                            <Run Text="{Binding TotalExpense, StringFormat={}{0:N2}}" />
                            <Run Text=" so'm" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Background="{DynamicResource AccentSoft}"
                    Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="Medium"
                            Foreground="{DynamicResource InkSecondary}"
                            Text="Sof natija" />
                        <TextBlock Margin="0,2,0,0" FontSize="22" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NetAmount, Converter={StaticResource NumberToBoolConverter}}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource Danger}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding NetAmount, StringFormat={}{0:N2}}" />
                            <Run Text=" so'm" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
