<Page
    x:Class="Forex.Wpf.Pages.Returns.Views.AddReturnPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Forex.Wpf.Pages.Returns.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    x:Name="RootPage"
    Title="AddReturnPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{DynamicResource PrimaryBackground}"
    TextElement.Foreground="{DynamicResource InkPrimary}"
    mc:Ignorable="d">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="40" />
			<RowDefinition Height="120" />
			<RowDefinition Height="50" />
			<RowDefinition Height="*" />
			<RowDefinition Height="64" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Border
                    Width="36"
                    Height="36"
                    Background="#E8EDFB"
                    CornerRadius="10">
					<md:PackIcon
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="#3B5BDB"
                        Kind="CartPlus" />
				</Border>
				<TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource InkPrimary}"
                    Text="Mahsulot qaytarish" />
			</StackPanel>

			<Border
                Padding="14,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#E8EDFB"
                CornerRadius="9">
				<StackPanel Orientation="Horizontal">
					<md:PackIcon
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        Foreground="#3B5BDB"
                        Kind="CashMultiple" />
					<TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#3B5BDB"
                        Text="{Binding Customer.CurrencyCode, StringFormat='Qaytarish valyutasi: {0}', FallbackValue='Mijoz tanlang', TargetNullValue='Mijoz tanlang'}" />
				</StackPanel>
			</Border>

			<Button
                x:Name="btnBack"
                Height="34"
                Padding="14,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                md:ButtonAssist.CornerRadius="9"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                Click="BtnBack_Click"
                Foreground="{DynamicResource InkSecondary}"
                ToolTip="Orqaga">
				<StackPanel Orientation="Horizontal">
					<md:PackIcon
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        Kind="ArrowLeft" />
					<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Orqaga" />
				</StackPanel>
			</Button>
		</Grid>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" MaxWidth="500" />
				<ColumnDefinition Width="20" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="80" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<Label Grid.Row="0" VerticalAlignment="Center" Content="Sana:" FontSize="14" />
				<Label Grid.Row="1" VerticalAlignment="Center" Content="Mijoz:" FontSize="14" />
				<Label Grid.Row="2" VerticalAlignment="Center" Content="Izox:" FontSize="14" />

				<Grid Grid.Row="0" Grid.Column="1">
					<controls:UserCalendar
                        x:Name="date"
                        Width="120"
                        Margin="0,2"
                        Padding="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{DynamicResource PrimaryBackground}"
                        FontSize="14"
                        SelectedDate="{Binding Date, Mode=TwoWay}" />
				</Grid>

				<Grid Grid.Row="1" Grid.Column="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="150" />
					</Grid.ColumnDefinitions>

					<controls:FloatingImageComboBox
						x:Name="cbxCustomerName"
						Grid.Column="0"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch"
						IsEditable="True"
						IsSearchEnabled="True"
						IsTextSearchEnabled="False"
						ItemsSource="{Binding FilteredCustomers}"
						PrimaryTextMemberPath="Name"
						SecondaryTextMemberPath="PhoneAndAddress"
						SelectedItem="{Binding Customer}"
						ShowImage="False"
						Text="{Binding CustomerInput, Mode=TwoWay}" />

					<Label
						Grid.Column="1"
						Margin="12,0,6,0"
						VerticalAlignment="Center"
						Content="Jami summa:"
						FontSize="14" />

					<Border
						Grid.Column="2"
						Margin="0,2"
						BorderBrush="{DynamicResource PrimaryTextColor}"
						BorderThickness="1"
						CornerRadius="4">
						<TextBox
							x:Name="tbxTotalSum"
							Padding="3,0"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							BorderThickness="0"
							FontSize="14"
							IsReadOnly="True"
							IsTabStop="False"
							Text="{Binding TotalAmount, StringFormat={}{0:N2}}"
							TextAlignment="Right" />
					</Border>
				</Grid>

				<Grid Grid.Row="2" Grid.Column="1">
					<Border
                        Margin="0,2"
                        BorderBrush="{DynamicResource PrimaryTextColor}"
                        BorderThickness="1"
                        CornerRadius="4">
						<TextBox
                            x:Name="tbxNote"
                            Padding="3,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding Note}"
                            TextAlignment="Left" />
					</Border>
				</Grid>
			</Grid>

			<Grid Grid.Column="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="150" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
					<RowDefinition Height="40" />
				</Grid.RowDefinitions>

				<TextBlock
                    Grid.Row="0"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontStyle="Italic"
                    FontWeight="Bold"
                    Text="{Binding Customer.CurrencyCode, StringFormat='Mijoz hisobi ({0}):', FallbackValue='Mijoz hisobi:', TargetNullValue='Mijoz hisobi:'}" />

				<TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Joriy:" />
				<TextBox
                    x:Name="beginBalans"
                    Grid.Row="1"
                    Margin="35,2,2,2"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="12"
                    IsReadOnly="True"
                    IsTabStop="False"
                    Text="{Binding TotalAmountWithUserBalance, StringFormat={}{0:N2}}" />

				<TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Qoldiq:" />
				<TextBox
                    x:Name="lastBalans"
                    Grid.Row="2"
                    Margin="35,2,2,2"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="12"
                    IsReadOnly="True"
                    Text="{Binding Customer.Balance, StringFormat={}{0:N2}}" />

				<TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Telefon:" />
				<TextBox
                    x:Name="tel"
                    Grid.Row="3"
                    Margin="42,2,2,2"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="12"
                    IsReadOnly="True"
                    IsTabStop="False"
                    Text="{Binding Customer.Phone}" />

				<TextBlock
                    Grid.Row="4"
                    VerticalAlignment="Center"
                    Text="Kurs (so'm):"
                    Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibilityConverter}}" />
				<Border
                    Grid.Row="4"
                    Grid.Column="1"
                    Width="110"
                    Height="26"
                    Margin="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    BorderBrush="{DynamicResource PrimaryTextColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="{Binding IsForeignCurrency, Converter={StaticResource BoolToVisibilityConverter}}">
					<TextBox
                        Padding="4,0"
                        VerticalContentAlignment="Center"
                        BorderThickness="0"
                        FontSize="12"
                        Text="{Binding ExchangeRate, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                        TextAlignment="Right" />
				</Border>
			</Grid>
		</Grid>

		<Grid Grid.Row="2" Margin="0,15,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" MinWidth="90" />
				<ColumnDefinition Width="1.2*" MinWidth="110" />
				<ColumnDefinition Width="*" MinWidth="70" />
				<ColumnDefinition Width="*" MinWidth="70" />
				<ColumnDefinition Width="*" MinWidth="60" />
				<ColumnDefinition Width="*" MinWidth="75" />
				<ColumnDefinition Width="*" MinWidth="70" />
				<ColumnDefinition Width="*" MinWidth="90" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<controls:FloatingInput
                x:Name="tbxScan"
                Grid.Column="0"
                Margin="2,0"
                Label="Skaner (qop/pachka)" />

			<controls:FloatingImageComboBox
                x:Name="cbxProduct"
                Grid.Column="1"
                Margin="2,0"
                ImageHeight="50"
                ImageMemberPath="ImagePath"
                ImageWidth="50"
                IsEditable="True"
                IsTextSearchEnabled="False"
                ItemsSource="{Binding FilteredProducts}"
                Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Label="Mahsulot"
                PrimaryTextMemberPath="Code"
                SecondaryTextMemberPath="Name"
                SelectedItem="{Binding CurrentSaleItem.Product}"
                ShowImage="True" />

			<controls:FloatingComboBox
                x:Name="cbxProductType"
                Grid.Column="2"
                Margin="2,0"
                DisplayMemberPath="Type"
                IsTextSearchEnabled="False"
                ItemsSource="{Binding CurrentSaleItem.Product.ProductTypes}"
                Label="Razmer"
                SelectedItem="{Binding CurrentSaleItem.ProductType, UpdateSourceTrigger=PropertyChanged}" />

			<controls:FloatingComboBox
                x:Name="cbxReturnUnit"
                Grid.Column="3"
                Margin="2,0"
                IsTextSearchEnabled="False"
                ItemsSource="{Binding ReturnUnits}"
                Label="Birlik"
                SelectedItem="{Binding SelectedReturnUnit, UpdateSourceTrigger=PropertyChanged}" />

			<controls:FloatingInput
                x:Name="tbxBundle"
                Grid.Column="4"
                Margin="2,0"
                Label="Miqdor"
                Text="{Binding CurrentSaleItem.BundleCount, UpdateSourceTrigger=PropertyChanged}" />

			<controls:FloatingInput
                x:Name="tbxUnitPrice"
                Grid.Column="5"
                Margin="2,0"
                Label="{Binding Customer.CurrencyCode, StringFormat='Narxi ({0})', FallbackValue='Narxi', TargetNullValue='Narxi'}"
                Text="{Binding CurrentSaleItem.UnitPrice, UpdateSourceTrigger=LostFocus}" />

			<controls:FloatingInput
                x:Name="tbxQuantity"
                Grid.Column="6"
                Margin="2,0"
                IsEnabled="False"
                Focusable="False"
                Label="Jami soni"
                Text="{Binding CurrentSaleItem.TotalCount, StringFormat={}{0:N0}, UpdateSourceTrigger=PropertyChanged}" />

			<controls:FloatingInput
                x:Name="tbxTotalAmount"
                Grid.Column="7"
                Margin="2,0,8,0"
                IsEnabled="False"
                Focusable="False"
                Label="{Binding Customer.CurrencyCode, StringFormat='Jami summa ({0})', FallbackValue='Jami summa', TargetNullValue='Jami summa'}"
                Text="{Binding CurrentSaleItem.Amount, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}" />

			<Grid Grid.Column="8" HorizontalAlignment="Right">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<Button
                    x:Name="btnCancel"
                    Grid.Column="0"
                    Height="32"
                    Margin="2,0"
                    Padding="14,0"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="#E11D48"
                    BorderThickness="1"
                    Command="{Binding CancelEditCommand}"
                    FontSize="14"
                    Foreground="#E11D48"
                    Visibility="{Binding IsEditingItem, Converter={StaticResource BoolToVisibilityConverter}}">
					<StackPanel Orientation="Horizontal">
						<md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Close" />
						<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Bekor" />
					</StackPanel>
				</Button>

				<Button
                    x:Name="btnAdd"
                    Grid.Column="1"
                    Height="32"
                    Margin="2,0"
                    Padding="16,0"
                    md:ButtonAssist.CornerRadius="9"
                    Background="#16A34A"
                    BorderThickness="0"
                    Command="{Binding AddCommand}"
                    FontSize="14"
                    Foreground="White">
					<StackPanel Orientation="Horizontal">
						<md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Plus" />
						<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Qo'shish" />
					</StackPanel>
				</Button>
			</Grid>
		</Grid>

		<Grid Grid.Row="3" Margin="0,5,0,5">
			<DataGrid
                x:Name="dataGrid"
                AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                AutoGenerateColumns="False"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="2"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                FontSize="14"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding SaleItems}"
                SelectedItem="{Binding SelectedSaleItem}"
                SelectionMode="Single"
                SelectionUnit="FullRow">

				<DataGrid.InputBindings>
					<MouseBinding
                        Command="{Binding ViewProductCommand}"
                        CommandParameter="{Binding SelectedItem, ElementName=dataGrid}"
                        Gesture="LeftDoubleClick" />
				</DataGrid.InputBindings>

				<DataGrid.Resources>
					<Style x:Key="RightAlignedCellStyle" TargetType="TextBlock">
						<Setter Property="TextAlignment" Value="Right" />
						<Setter Property="Padding" Value="0,0,5,0" />
					</Style>
					<Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
						<Setter Property="TextAlignment" Value="Center" />
					</Style>
					<Style TargetType="DataGridColumnHeader">
						<Setter Property="HorizontalContentAlignment" Value="Center" />
						<Setter Property="FontWeight" Value="SemiBold" />
					</Style>
				</DataGrid.Resources>

				<DataGrid.Columns>
					<DataGridTemplateColumn Width="60" Header="T/r">
						<DataGridTemplateColumn.CellStyle>
							<Style TargetType="DataGridCell">
								<Setter Property="HorizontalAlignment" Value="Center" />
								<Setter Property="VerticalContentAlignment" Value="Center" />
							</Style>
						</DataGridTemplateColumn.CellStyle>
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Converter={StaticResource IndexConverter}}" />
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTextColumn
                        Width="*"
                        MinWidth="80"
                        Binding="{Binding Product.Code}"
                        Header="Kod" />

					<DataGridTextColumn
                        Width="1.5*"
                        MinWidth="100"
                        Binding="{Binding Product.Name}"
                        Header="Nomi" />

					<DataGridTextColumn
                        Width="*"
                        Binding="{Binding ProductType.Type}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="Razmer" />

					<DataGridTextColumn
                        Width="*"
                        Binding="{Binding BundleCount, StringFormat={}{0:N0}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Qop soni" />

					<DataGridTextColumn
                        Width="*"
                        Binding="{Binding BundleItemCount, StringFormat={}{0:N2}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Qopda" />

					<DataGridTextColumn
                        Width="*"
                        Binding="{Binding UnitPrice, StringFormat={}{0:N2}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Narxi" />

					<DataGridTextColumn
                        Width="*"
                        Binding="{Binding TotalCount, StringFormat={}{0:N0}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Jami soni" />

					<DataGridTextColumn
                        Width="*"
                        Binding="{Binding Amount, StringFormat={}{0:N2}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Jami summa" />

					<DataGridTemplateColumn Width="90" Header="Amallar">
						<DataGridTemplateColumn.HeaderStyle>
							<Style TargetType="DataGridColumnHeader">
								<Setter Property="HorizontalContentAlignment" Value="Center" />
								<Setter Property="FontWeight" Value="SemiBold" />
							</Style>
						</DataGridTemplateColumn.HeaderStyle>
						<DataGridTemplateColumn.CellStyle>
							<Style TargetType="DataGridCell">
								<Setter Property="Padding" Value="4" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="DataGridCell">
											<StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
												<Button
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Style="{StaticResource EditActionButton}"
                                                    ToolTip="Tahrirlash">
													<md:PackIcon Width="16" Height="16" Kind="Pencil" />
												</Button>
												<Button
                                                    Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DeleteActionButton}"
                                                    ToolTip="O'chirish">
													<md:PackIcon Width="16" Height="16" Kind="Delete" />
												</Button>
											</StackPanel>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</DataGridTemplateColumn.CellStyle>
					</DataGridTemplateColumn>
				</DataGrid.Columns>
			</DataGrid>
		</Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Margin="0,0,8,0" Padding="14,8" Background="#EEF2FF" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#6470B0" Text="Qatorlar" />
                    <TextBlock Margin="0,2,0,0" FontSize="17" FontWeight="Bold" Foreground="#3949AB" Text="{Binding TotalRowsCount}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Margin="0,0,8,0" Padding="14,8" Background="#E6FBF6" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#0F9488" Text="Turli mahsulot" />
                    <TextBlock Margin="0,2,0,0" FontSize="17" FontWeight="Bold" Foreground="#0D8276" Text="{Binding DistinctProductsCount}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Margin="0,0,8,0" Padding="14,8" Background="#FFF6E6" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#B7791F" Text="Jami qoplar" />
                    <TextBlock Margin="0,2,0,0" FontSize="17" FontWeight="Bold" Foreground="#A66A12" Text="{Binding TotalBundlesCount}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Padding="14,8" Background="#E9F8EE" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#2E8B57" Text="Jami soni" />
                    <TextBlock Margin="0,2,0,0" FontSize="17" FontWeight="Bold" Foreground="#1B7A3E" Text="{Binding TotalQuantityCount}" />
                </StackPanel>
            </Border>
        </Grid>

		<StackPanel
            Grid.Column="1"
            Margin="16,0,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">

			<Button
                x:Name="btnClear"
                Height="36"
                Margin="0,0,10,0"
                Padding="16,0"
                md:ButtonAssist.CornerRadius="9"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="#E11D48"
                BorderThickness="1"
                Command="{Binding ClearSaleCommand}"
                Foreground="#E11D48"
                ToolTip="Barcha ma'lumotlarni tozalash">
				<StackPanel Orientation="Horizontal">
					<md:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="DeleteSweepOutline" />
					<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
				</StackPanel>
			</Button>

			<Button
                x:Name="btnSubmit"
                Height="36"
                Padding="22,0"
                md:ButtonAssist.CornerRadius="9"
                md:ElevationAssist.Elevation="Dp2"
                Background="#16A34A"
                BorderThickness="0"
                Command="{Binding SubmitCommand}"
                Foreground="White">
				<StackPanel Orientation="Horizontal">
					<md:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="Check" />
					<TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Yuborish" />
				</StackPanel>
			</Button>
		</StackPanel>
		</Grid>

		<Grid
            Grid.RowSpan="5"
            Background="#AA000000"
            IsHitTestVisible="{Binding IsPopupOpen}"
            PreviewMouseDown="ClosePopup_MouseDown"
            Visibility="{Binding IsPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}">
			<Border
                MaxHeight="800"
                MaxWidth="1200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SurfaceCard}"
                CornerRadius="12"
                Padding="30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="350" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Info (Left) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontSize="28"
                            FontWeight="Bold"
                            Text="{Binding PopupItem.Product.Name}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="20"
                            Foreground="{DynamicResource InkMuted}"
                            Text="{Binding PopupItem.Product.Code}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="Razmer:" />
                            <TextBlock Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="Bold" Text="{Binding PopupItem.ProductType.Type}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="1 qopda:" />
                            <TextBlock Grid.Row="2" Grid.Column="2" FontSize="16" Text="{Binding PopupItem.ProductType.BundleItemCount, StringFormat={}{0} ta}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="Qop soni:" />
                            <TextBlock Grid.Row="4" Grid.Column="2" FontSize="16" Text="{Binding PopupItem.BundleCount, StringFormat={}{0:N0}}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="Jami soni:" />
                            <TextBlock Grid.Row="6" Grid.Column="2" FontSize="16" Text="{Binding PopupItem.TotalCount, StringFormat={}{0:N0} ta}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="Narxi:" />
                            <TextBlock Grid.Row="8" Grid.Column="2" FontSize="16" Text="{Binding PopupItem.UnitPrice, StringFormat={}{0:N2}}" />

                            <TextBlock Grid.Row="10" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource InkSecondary}" Text="Jami summa:" />
                            <TextBlock Grid.Row="10" Grid.Column="2" FontSize="20" FontWeight="Bold" Foreground="Green" Text="{Binding PopupItem.Amount, StringFormat={}{0:N2}}" />
                        </Grid>
                    </StackPanel>

                    <!-- Image (Right) -->
                    <Border Grid.Column="2" Width="400" Height="400" Background="{DynamicResource SurfaceMuted}" CornerRadius="8" VerticalAlignment="Center">
                        <Image Source="{Binding PopupItem.Product.DisplayImagePath}" Stretch="Uniform" />
                    </Border>
                </Grid>
			</Border>
		</Grid>
	</Grid>
</Page>
