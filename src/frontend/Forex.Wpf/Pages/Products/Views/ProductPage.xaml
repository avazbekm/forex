<Page x:Class="Forex.Wpf.Pages.Products.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:Forex.Wpf.Resources.UserControls"
      xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      x:Name="RootPage"
      Title="ProductPage"
      d:DesignHeight="650"
      d:DesignWidth="1100"
      mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,0,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource InkMuted}" />
        </Style>

        <Style x:Key="StatChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource SurfacePage}" TextElement.Foreground="{DynamicResource InkPrimary}">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Grid Grid.Row="0" Margin="2,0,2,4">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="42"
                        Height="42"
                        Background="{DynamicResource AccentSoft}"
                        CornerRadius="11">
                        <md:PackIcon
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource Accent}"
                            Kind="PackageVariant" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{DynamicResource InkPrimary}"
                            Text="Mahsulot kirimlari" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource InkFaint}"
                            Text="Ombor kirim tarixi va boshqaruvi" />
                    </StackPanel>
                </StackPanel>

                <controls:FloatingInput
                    x:Name="tbxScan"
                    Width="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Label="Skaner — shtrix-kod (qop)" />

                <Button
                    x:Name="btnBack"
                    Height="38"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource HairlineBorder}"
                    BorderThickness="1"
                    Click="BtnBack_Click"
                    Foreground="{DynamicResource InkSecondary}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Kind="ArrowLeft" />
                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Orqaga" />
                    </StackPanel>
                </Button>
            </Grid>

            <!--  Entry form (placement preserved)  -->
            <Border
                Grid.Row="1"
                Margin="0,14,0,0"
                Padding="14,12"
                Background="{DynamicResource SurfaceCard}"
                CornerRadius="14"
                md:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" MaxWidth="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <controls:UserCalendar
                    x:Name="date"
                    Width="120"
                    Height="32"
                    HorizontalAlignment="Left"
                    FontSize="16"
                    SelectedDate="{Binding CurrentProductEntry.Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Product -->
                    <controls:FloatingImageComboBox
                    Grid.Column="1" Grid.ColumnSpan="2"
                    Label="Mahsulot"
                    Text="{Binding ProductCode, UpdateSourceTrigger=LostFocus}"
                    ItemsSource="{Binding AvailableProducts}"
                    Margin="2,0"
                    SelectedItem="{Binding CurrentProduct, UpdateSourceTrigger=PropertyChanged}"
                    x:Name="productCombo"
                    IsEditable="True"
                    IsSearchEnabled="True"
                    ImageMemberPath="ImagePath"
                    PrimaryTextMemberPath="Code"
                    SecondaryTextMemberPath="Name"
                    ShowImage="True"
                    ImageWidth="50"
                    ImageHeight="50"
                    ItemHoverScale="2"
                    Visibility="{Binding IsNewProductMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <controls:FloatingInput
                    x:Name="tbxCode"
                    Grid.Column="1"
                    Margin="2,0"
                    Label="Kodi"
                    Visibility="{Binding IsNewProductMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Text="{Binding CurrentProduct.Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <controls:FloatingInput
                    x:Name="tbxName"
                    Grid.Column="2"
                    Margin="2,0"
                    Label="Nomi"
                    Visibility="{Binding IsNewProductMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Text="{Binding CurrentProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <!-- Product -->

                    <controls:FloatingComboBox
                    x:Name="cbxProductionOrigin"
                    Grid.Column="3"
                    Margin="2,0"
                    IsEnabled="{Binding IsProductionOriginEnabled}"
                    ItemsSource="{Binding ProductionOrigins}"
                    Label="Tayyorlanish usuli"
                    SelectedItem="{Binding CurrentProductEntry.ProductionOrigin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Type -->
                    <controls:FloatingComboBox
                    x:Name="cbxProductType"
                    Grid.Column="4"
                    Margin="2,0"
                    DisplayMemberPath="Type"
                    IsEditable="True"
                    ItemsSource="{Binding CurrentProduct.ProductTypes}"
                    Label="Razmer"
                    Visibility="{Binding IsNewProductMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                    SelectedItem="{Binding CurrentProduct.SelectedType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Text="{Binding ProductType, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <controls:FloatingInput
                    x:Name="tbxRazmer"
                    Grid.Column="4"
                    Margin="2,0"
                    Label="Razmer"
                    Visibility="{Binding IsNewProductMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Text="{Binding CurrentProduct.SelectedType.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <!-- Type -->

                    <controls:FloatingInput
                    x:Name="tbxBundle"
                    Grid.Column="5"
                    Margin="2,0"
                    Label="Qop soni"
                    Text="{Binding CurrentProductEntry.BundleCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <controls:FloatingInput
                    x:Name="tbxBundleItemCount"
                    Grid.Column="6"
                    Margin="2,0"
                    Label="Donasi"
                    IsReadOnly="{Binding CurrentProduct.SelectedType.Id, Converter={StaticResource NumberToBoolConverter}}"
                    Text="{Binding CurrentProductEntry.BundleItemCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <controls:FloatingInput
                    x:Name="tbxQuantity"
                    Grid.Column="7"
                    Margin="2,0"
                    IsReadOnly="True"
                    Label="Jami soni"
                    Text="{Binding CurrentProductEntry.Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <controls:FloatingInput
                    x:Name="tbxCostPrice"
                    Grid.Column="8"
                    Margin="2,0"
                    Label="Tan narxi"
                    Text="{Binding CurrentProductEntry.UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" />

                    <controls:FloatingFileInput
                    x:Name="fileInput"
                    Grid.Column="9"
                    Margin="2,0"
                    MinWidth="100"
                    MaxWidth="150"
                    Label="Rasm"
                    Visibility="{Binding IsNewProductMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    FileName="{Binding CurrentProduct.ImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Button
                    x:Name="btnAdd"
                    Grid.Column="10"
                    Height="32"
                    Margin="2,0,0,0"
                    Padding="16,0"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource SuccessStrong}"
                    BorderThickness="0"
                    Command="{Binding SaveCommand}"
                    Foreground="{DynamicResource OnAccent}"
                    FontSize="14">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="ContentSave" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Saqlash" />
                        </StackPanel>
                    </Button>

                    <Button
                    x:Name="btnCancel"
                    Grid.Column="11"
                    Height="32"
                    Margin="6,0,0,0"
                    Padding="14,0"
                    md:ButtonAssist.CornerRadius="9"
                    Background="{DynamicResource SurfaceCard}"
                    BorderBrush="{DynamicResource Danger}"
                    BorderThickness="1"
                    Command="{Binding CancelCommand}"
                    Foreground="{DynamicResource Danger}"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                    FontSize="14">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Kind="Close" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Bekor" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  Filter bar  -->
            <Border
                Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14,12"
                Background="{DynamicResource SurfaceMuted}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Boshlanish" />
                        <controls:UserCalendar
                            x:Name="filterFrom"
                            Width="120"
                            Height="30"
                            AllowEmpty="True"
                            Hint="dd.MM.yyyy"
                            FontSize="14"
                            SelectedDate="{Binding FilterFromDate, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tugash" />
                        <controls:UserCalendar
                            x:Name="filterTo"
                            Width="120"
                            Height="30"
                            AllowEmpty="True"
                            Hint="dd.MM.yyyy"
                            FontSize="14"
                            SelectedDate="{Binding FilterToDate, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Mahsulot" />
                        <controls:FloatingImageComboBox
                            x:Name="filterProductCombo"
                            Width="200"
                            IsEditable="True"
                            IsSearchEnabled="True"
                            IsTextSearchEnabled="False"
                            ItemsSource="{Binding FilteredFilterProducts}"
                            PrimaryTextMemberPath="Code"
                            SecondaryTextMemberPath="Name"
                            SelectedItem="{Binding SelectedFilterProduct, Mode=TwoWay}"
                            ShowImage="False"
                            Text="{Binding FilterProductText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="O'lcham" />
                        <controls:FloatingComboBox
                            Width="120"
                            ItemsSource="{Binding AvailableSizes}"
                            SelectedItem="{Binding SelectedSize, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                        <Button
                            Height="30"
                            Padding="14,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="{DynamicResource SurfaceCard}"
                            BorderBrush="{DynamicResource HairlineBorder}"
                            BorderThickness="1"
                            Command="{Binding ClearFiltersCommand}"
                            Foreground="{DynamicResource InkSecondary}"
                            ToolTip="Filterlarni tozalash">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Kind="FilterRemoveOutline" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="" />
                        <Button
                            Height="30"
                            Padding="14,0"
                            md:ButtonAssist.CornerRadius="9"
                            Background="{DynamicResource SuccessStrong}"
                            BorderThickness="0"
                            Command="{Binding ExportToExcelCommand}"
                            Foreground="{DynamicResource OnAccent}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Kind="FileExcel" />
                                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Excel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  DataGrid  -->
            <DataGrid Grid.Row="3"
                x:Name="dataGrid"
                Margin="0,14,0,0"
                AutoGenerateColumns="False"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                FontSize="14"
                ColumnHeaderHeight="40"
                RowHeight="40"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
                VirtualizingStackPanel.VirtualizationMode="Standard"
                EnableRowVirtualization="True"
                ItemsSource="{Binding ProductEntriesView}"
                SelectedItem="{Binding SelectedProductEntry}"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                HeadersVisibility="Column"
                IsReadOnly="True">

                <DataGrid.Resources>
                    <Style x:Key="RightAlignedCellStyle" TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Right" />
                        <Setter Property="Padding" Value="0,0,5,0" />
                    </Style>

                    <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource GridHeaderBg}" />
                        <Setter Property="Foreground" Value="{DynamicResource GridHeaderInk}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="60" Header="T/r">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                       Converter={StaticResource IndexConverter}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding Date, Mode=TwoWay, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="Sana" />

                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding ProductType.Product.Code, Mode=TwoWay}"
                        Header="Kod" />

                    <DataGridTextColumn
                        Width="1.3*"
                        MinWidth="100"
                        Binding="{Binding ProductType.Product.Name}"
                        Header="Nomi" />

                    <DataGridTextColumn
                        Width="*"
                        MinWidth="100"
                        Binding="{Binding ProductionOrigin}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="Tayyorlanish usuli" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ProductType.Type}"
                        ElementStyle="{StaticResource CenterAlignedCellStyle}"
                        Header="Razmer" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding BundleCount, StringFormat={}{0:N0}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Qop soni" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding BundleItemCount, StringFormat={}{0:N0}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Donasi" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Count, StringFormat={}{0:N0}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Jami soni" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding UnitPrice, StringFormat={}{0:N0}}"
                        ElementStyle="{StaticResource RightAlignedCellStyle}"
                        Header="Tannarxi" />

                    <DataGridTemplateColumn Width="104" Header="Amallar">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <StackPanel
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <Button
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Style="{StaticResource EditActionButton}"
                                                    ToolTip="Tahrirlash">
                                                    <md:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                                </Button>
                                                <Button
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DeleteActionButton}"
                                                    ToolTip="O'chirish">
                                                    <md:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!--  Totals + Pagination  -->
            <Border
                Grid.Row="4"
                Margin="0,14,0,0"
                Padding="12,10"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource HairlineBorder}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource AccentSoft}" Style="{StaticResource StatChip}">
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="{DynamicResource InkSecondary}" Text="Kirimlar" />
                                <TextBlock Margin="0,2,0,0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Accent}" Text="{Binding TotalEntries, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource WarningSoft}" Style="{StaticResource StatChip}">
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="{DynamicResource Warning}" Text="Jami dona" />
                                <TextBlock Margin="0,2,0,0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Warning}" Text="{Binding TotalStockCount, StringFormat={}{0:N0}, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource SuccessSoft}" Style="{StaticResource StatChip}">
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="{DynamicResource Success}" Text="Jami summa (so'm)" />
                                <TextBlock Margin="0,2,0,0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Success}" Text="{Binding TotalStockValue, StringFormat={}{0:N0}, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="32" Height="32" Margin="2,0" Padding="0"
                            md:ButtonAssist.CornerRadius="8"
                            Background="Transparent" BorderBrush="{DynamicResource HairlineBorder}" BorderThickness="1"
                            Command="{Binding GoToFirstPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            ToolTip="Birinchi sahifa">
                            <md:PackIcon Kind="ChevronDoubleLeft" />
                        </Button>
                        <Button
                            Width="32" Height="32" Margin="2,0" Padding="0"
                            md:ButtonAssist.CornerRadius="8"
                            Background="Transparent" BorderBrush="{DynamicResource HairlineBorder}" BorderThickness="1"
                            Command="{Binding GoToPreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            ToolTip="Oldingi sahifa">
                            <md:PackIcon Kind="ChevronLeft" />
                        </Button>

                        <ItemsControl Margin="4,0" ItemsSource="{Binding VisiblePageNumbers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="32" Height="32" Margin="1,0" Padding="0"
                                        md:ButtonAssist.CornerRadius="8"
                                        Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding}">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource HairlineBorder}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="...">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding />
                                                                <Binding Path="DataContext.CurrentPage" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button
                            Width="32" Height="32" Margin="2,0" Padding="0"
                            md:ButtonAssist.CornerRadius="8"
                            Background="Transparent" BorderBrush="{DynamicResource HairlineBorder}" BorderThickness="1"
                            Command="{Binding GoToNextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            ToolTip="Keyingi sahifa">
                            <md:PackIcon Kind="ChevronRight" />
                        </Button>
                        <Button
                            Width="32" Height="32" Margin="2,0" Padding="0"
                            md:ButtonAssist.CornerRadius="8"
                            Background="Transparent" BorderBrush="{DynamicResource HairlineBorder}" BorderThickness="1"
                            Command="{Binding GoToLastPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            ToolTip="Oxirgi sahifa">
                            <md:PackIcon Kind="ChevronDoubleRight" />
                        </Button>

                        <Border
                            Margin="8,0,0,0" Padding="8,4"
                            Background="{DynamicResource SurfacePage}" BorderBrush="{DynamicResource HairlineBorder}" BorderThickness="1" CornerRadius="8">
                            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource GridHeaderInk}">
                                <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding TotalPages, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
