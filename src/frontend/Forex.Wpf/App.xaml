<Application
    x:Class="Forex.Wpf.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Forex.Wpf"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  begin::Custom Theme  -->
                <ResourceDictionary Source="/Resources/Themes/LightTheme.xaml" />
                <!--  end::Custom Theme  -->

                <!--  begin::Material Design  -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Blue" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <!--  end::Material Design  -->

                <!--  begin::Custom styles  -->
                <ResourceDictionary Source="/Resources/Styles/FloatingLable.xaml" />
                <ResourceDictionary Source="/Resources/Styles/ContextMenuButtonStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/ActionButtons.xaml" />
                <!--  end::Custom styles  -->

                <!--  begin::Converters  -->
                <ResourceDictionary Source="Resources/Converters.xaml" />
                <!--  end::Converters  -->

                <!--  Sizning resurs faylingiz  -->
                <ResourceDictionary Source="/Resources/Styles/ScrollBarStyles.xaml" />
                <!--  boshqa ranglar yoki style fayllarini ham shu yerga qo‘shishingiz mumkin  -->
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed" />
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed" />
            </Style>
            <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
