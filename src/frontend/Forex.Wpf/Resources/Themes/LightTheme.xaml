<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Semantic surfaces (zamonaviy sahifalar uchun, theme bilan boshqariladi)  -->
    <SolidColorBrush x:Key="SurfacePage" Color="#F4F6FA" />
    <SolidColorBrush x:Key="SurfaceCard" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceMuted" Color="#F8FAFD" />
    <SolidColorBrush x:Key="SurfaceChip" Color="#EEF1F6" />
    <SolidColorBrush x:Key="HairlineBorder" Color="#EAEEF5" />
    <SolidColorBrush x:Key="GridHeaderBg" Color="#F4F7FC" />
    <SolidColorBrush x:Key="GridHeaderInk" Color="#5A6477" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#F0F2F6" />
    <SolidColorBrush x:Key="InkPrimary" Color="#1F2937" />
    <SolidColorBrush x:Key="InkSecondary" Color="#475467" />
    <SolidColorBrush x:Key="InkMuted" Color="#7A8699" />
    <SolidColorBrush x:Key="InkFaint" Color="#9AA4B2" />

    <!--  Backgrounds  -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="#E0F2FE" />
    <!--  Oq  -->
    <SolidColorBrush x:Key="SecondaryBackground" Color="#F5F5F5" />
    <!--  Juda och kulrang  -->
    <SolidColorBrush x:Key="SelectedBackground" Color="#E3F2FD" />
    <!--  Pastel ko‘k (tanlangan element)  -->
    <SolidColorBrush x:Key="OtherBackground" Color="#FFFDE7" />
    <!--  Pastel sariq  -->

    <!--  Borders  -->
    <SolidColorBrush x:Key="PrimaryBorderColor" Color="#E0E0E0" />
    <!--  Och kulrang  -->
    <SolidColorBrush x:Key="SecondaryBorderColor" Color="#BDBDBD" />
    <!--  Biroz to‘qroq kulrang  -->
    <SolidColorBrush x:Key="SelectedBorderColor" Color="#2196F3" />
    <!--  Ko‘k aksent  -->

    <!--  Text  -->
    <SolidColorBrush x:Key="PrimaryTextColor" Color="#212121" />
    <!--  Asosiy qora matn  -->
    <SolidColorBrush x:Key="SecondaryTextColor" Color="#616161" />
    <!--  Ikkilamchi kulrang matn  -->
    <SolidColorBrush x:Key="DisabledTextColor" Color="#9E9E9E" />
    <!--  O‘chirilgan matn  -->
    <SolidColorBrush x:Key="MainMenuTextColor" Color="White" />
    <!--  Oppoq  -->

    <!--  Accent Colors  -->
    <SolidColorBrush x:Key="AccentColor" Color="#2196F3" />
    <!--  Ko‘k (asosiy aksent)  -->
    <SolidColorBrush x:Key="AccentLightColor" Color="#BBDEFB" />
    <!--  Ko‘kning ochroq varianti  -->
    <SolidColorBrush x:Key="AccentDarkColor" Color="#1976D2" />
    <!--  Ko‘kning to‘qroq varianti  -->

    <!--  Status Colors  -->
    <SolidColorBrush x:Key="SuccessColor" Color="#2DAA39" />
    <!--  Yashil  -->
    <SolidColorBrush x:Key="WarningColor" Color="#FFC107" />
    <!--  Sariq  -->
    <SolidColorBrush x:Key="ErrorColor" Color="#F44336" />
    <!--  Qizil  -->

    <!--  Button Colors  -->
    <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#2196F3" />
    <SolidColorBrush x:Key="PrimaryButtonForeground" Color="White" />

    <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#EEEEEE" />
    <SolidColorBrush x:Key="SecondaryButtonForeground" Color="#212121" />

    <SolidColorBrush x:Key="DangerButtonBackground" Color="#F44336" />
    <SolidColorBrush x:Key="DangerButtonForeground" Color="White" />

    <SolidColorBrush x:Key="DisabledButtonBackground" Color="#E0E0E0" />
    <SolidColorBrush x:Key="DisabledButtonForeground" Color="#9E9E9E" />

    <!--  Back Button  -->
    <SolidColorBrush x:Key="BackButtonBackground" Color="#EEEEEE" />
    <SolidColorBrush x:Key="BackButtonForeground" Color="#212121" />
    <SolidColorBrush x:Key="BackButtonBorder" Color="#BDBDBD" />

    <!--  Success Button  -->
    <SolidColorBrush x:Key="SuccessButtonBackground" Color="#28a745" />
    <SolidColorBrush x:Key="SuccessButtonForeground" Color="White" />
    <SolidColorBrush x:Key="SuccessButtonBorder" Color="#28a745" />

    <!--  ========================================================================
          Page semantic tokens — sahifalardagi hardcode ranglar shu yerga jamlangan.
          Har biri yorug'/tungi mavzuda mos qiymat oladi (DarkTheme.xaml ko'zgusi).
          ========================================================================  -->

    <!--  Color qiymatlari (Color="..." kerak bo'lgan joylar uchun: gradient, soya)  -->
    <Color x:Key="AccentColorValue">#3B5BDB</Color>
    <Color x:Key="SuccessColorValue">#15803D</Color>
    <Color x:Key="WarningColorValue">#B7791F</Color>
    <Color x:Key="DangerColorValue">#DC2626</Color>
    <Color x:Key="TealColorValue">#0F9488</Color>
    <Color x:Key="IconVioletColorValue">#673AB7</Color>
    <Color x:Key="OnAccentColorValue">#FFFFFF</Color>
    <Color x:Key="ScrimColorValue">#AA000000</Color>

    <!--  Accent (asosiy ko'k-binafsha)  -->
    <SolidColorBrush x:Key="Accent" Color="#3B5BDB" />
    <SolidColorBrush x:Key="AccentSoft" Color="#E8EDFB" />
    <SolidColorBrush x:Key="OnAccent" Color="#FFFFFF" />

    <!--  Success (yashil)  -->
    <SolidColorBrush x:Key="Success" Color="#15803D" />
    <SolidColorBrush x:Key="SuccessStrong" Color="#16A34A" />
    <SolidColorBrush x:Key="SuccessSoft" Color="#E9F8EE" />
    <SolidColorBrush x:Key="SuccessMuted" Color="#5E8B6F" />

    <!--  Warning (amber)  -->
    <SolidColorBrush x:Key="Warning" Color="#B7791F" />
    <SolidColorBrush x:Key="WarningSoft" Color="#FFF6E6" />

    <!--  Danger (qizil)  -->
    <SolidColorBrush x:Key="Danger" Color="#DC2626" />
    <SolidColorBrush x:Key="DangerSoft" Color="#FDECEA" />

    <!--  Teal / Info  -->
    <SolidColorBrush x:Key="Teal" Color="#0F9488" />
    <SolidColorBrush x:Key="TealSoft" Color="#E6FBF6" />

    <!--  Dekorativ ikona ranglari (toifa kartalari)  -->
    <SolidColorBrush x:Key="IconViolet" Color="#673AB7" />
    <SolidColorBrush x:Key="IconPink" Color="#B43E7C" />
    <SolidColorBrush x:Key="IconPinkSoft" Color="#FDECF3" />

    <!--  Kuchli chegara (hover/urg'u) va modal qoplama  -->
    <SolidColorBrush x:Key="BorderStrong" Color="#C7CFDD" />
    <SolidColorBrush x:Key="Scrim" Color="#AA000000" />

</ResourceDictionary>
